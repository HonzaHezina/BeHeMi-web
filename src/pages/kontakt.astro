---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { RESERVE_URL } from '../data/home';

// Statika only (CLAUDE.md pravidlo 1): místo odesílacího formuláře z exportu
// dáváme přímé akce — mailto / tel — a rezervaci posíláme ven na WordPress.
const contactBlocks = [
  { label: 'Adresa', lines: ['Vinohradská 1438/70', '130 00 Praha 3'] },
  { label: 'Doprava', lines: ['Metro A, tram 11 a 13 — Jiřího z Poděbrad, 2 min pěšky'] },
  { label: 'Telefon', lines: ['+420 603 989 762'], href: 'tel:+420603989762' },
  { label: 'E-mail', lines: ['info@bohemi.fit'], href: 'mailto:info@bohemi.fit' },
  { label: 'Otevírací doba', lines: ['Pondělí — pátek dle rozvrhu lekcí'] },
];

const MAPS_URL = 'https://www.google.com/maps/search/?api=1&query=Vinohradsk%C3%A1%201438%2F70%2C%20Praha%203';
// TODO: doplnit reálné profily na sociálních sítích.
const socials = [
  { label: 'Facebook', href: 'https://www.facebook.com/' },
  { label: 'Instagram', href: 'https://www.instagram.com/' },
];
---
<Layout
  title="Kontakt — BoHeMi fitness, Vinohrady Praha"
  description="Najdeš nás na Vinohradská 1438/70, Praha 3 — dvě minuty od metra Jiřího z Poděbrad. Napiš na info@bohemi.fit nebo zavolej +420 603 989 762."
>
  <Header current="/kontakt/" />
  <main>
    <!-- HERO -->
    <section class="relative mx-auto max-w-[1220px] overflow-hidden px-5 pb-10 pt-16 md:px-8 md:pt-20">
      <div
        class="pointer-events-none absolute right-0 top-0 h-[400px] w-[400px] rounded-full"
        style="background:radial-gradient(circle, rgba(47,90,64,0.13), rgba(47,90,64,0) 70%);"
        aria-hidden="true"
      >
      </div>
      <div class="relative">
        <h1 class="text-[clamp(40px,6.2vw,76px)] font-extrabold leading-[0.98] tracking-[-0.035em]">
          Najdeš nás na <span class="font-medium italic text-brand">Jiřáku</span>
        </h1>
        <p class="mt-6 max-w-[52ch] text-[clamp(18px,2.1vw,22px)] leading-[1.45] text-ink-warm">
          Vinohradská 1438/70, Praha 3. Dvě minuty pěšky od metra a tramvaje Jiřího z Poděbrad.
        </p>
      </div>
    </section>

    <!-- DETAILY + MAPA / AKCE -->
    <section class="mx-auto grid max-w-[1220px] gap-10 px-5 pb-16 md:grid-cols-2 md:px-8 md:pb-23">
      <!-- Sloupec: údaje -->
      <div>
        <div class="mb-8 flex flex-col gap-7">
          {contactBlocks.map((b) => (
            <div>
              <div class="mb-2 text-[13px] font-bold uppercase tracking-[0.06em] text-ink-faint">{b.label}</div>
              {b.href ? (
                <a href={b.href} class="text-[19px] leading-[1.5] text-ink hover:text-brand">{b.lines[0]}</a>
              ) : (
                <div class="text-[19px] leading-[1.5] text-ink">
                  {b.lines.map((l, i) => (<>{i > 0 && <br />}{l}</>))}
                </div>
              )}
            </div>
          ))}
        </div>
        <div class="flex flex-wrap gap-3">
          {socials.map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-full border-[1.5px] border-border-button px-[18px] py-2.5 text-[15px] font-semibold text-ink-line transition-colors hover:border-brand hover:text-brand"
            >
              {s.label}
            </a>
          ))}
        </div>
      </div>

      <!-- Sloupec: mapa + akce -->
      <div>
        <a
          href={MAPS_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="group relative mb-6 block h-60 overflow-hidden rounded-[18px] media-green"
          aria-label="Otevřít adresu BoHeMi v Mapách Google"
        >
          <div
            class="absolute inset-0"
            style="background-image:repeating-linear-gradient(0deg, rgba(255,255,255,0.10) 0 1px, transparent 1px 30px),repeating-linear-gradient(90deg, rgba(255,255,255,0.10) 0 1px, transparent 1px 30px);"
            aria-hidden="true"
          >
          </div>
          <span class="absolute bottom-4 left-4 inline-flex items-center gap-2 rounded-full bg-ink-dark/55 px-3.5 py-1.5 text-[13px] font-semibold text-cream backdrop-blur-sm transition-colors group-hover:bg-ink-dark/75">
            Otevřít v mapách ↗
          </span>
        </a>

        <div class="rounded-[18px] border border-border bg-surface p-7">
          <h2 class="mb-2 text-[21px] font-extrabold tracking-[-0.02em]">Napiš nám</h2>
          <p class="mb-5 text-[15.5px] leading-[1.55] text-ink-soft">Otázky k lekcím, programu Cesta nebo firmám? Napiš nebo zavolej — ozveme se ti.</p>
          <div class="flex flex-col gap-3">
            <a
              href="mailto:info@bohemi.fit"
              class="inline-flex cursor-pointer items-center justify-center gap-2 rounded-full bg-brand px-6 py-3.5 text-base font-bold text-cream transition-colors hover:bg-brand-dark focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-surface"
            >
              Napsat e-mail
            </a>
            <a
              href="tel:+420603989762"
              class="inline-flex cursor-pointer items-center justify-center gap-2 rounded-full border-[1.5px] border-border-button px-6 py-3.5 text-base font-bold text-ink transition-colors hover:border-brand hover:text-brand"
            >
              Zavolat +420 603 989 762
            </a>
          </div>
          <p class="mt-5 border-t border-border pt-5 text-[15px] leading-[1.55] text-ink-soft">
            Chceš rovnou na lekci nebo do příští skupiny programu Cesta?
            <a href={RESERVE_URL} target="_blank" rel="noopener noreferrer" class="font-semibold text-brand hover:text-brand-dark">Rezervovat online ↗</a>
          </p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
