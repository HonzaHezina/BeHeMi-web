---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import MediaFrame from '../components/MediaFrame.astro';
import { RESERVE_URL } from '../data/home';

// Reálná data z bohemi.fit/akademie-cirk-la-putyka/ a /hernicka/.
// Ceny ověřené proti WP 5. 7. 2026 (4 000 / 4 600 / 5 500 Kč) — drž v synku
// s cenik.astro a en/pricing.astro.
// TODO(Honza): před nasazením ověřit termíny semestru — WP uvádí
// „letní semestr 16. 9. 2026 – 27. 1. 2027", což vypadá jako zimní.
// WP u kurzů ukazuje i počty míst (10/9/11) — vypadá to jako volná místa
// z bookingu, ne kapacita → na statický web nepatří (viz CLAUDE.md).
// id = stabilní kotva /krouzky-pro-deti/#<id> (ASCII, nikdy neměnit) —
// vedou na ně odkazy z HP a rozcestníku, stejná logika jako u typů lekcí.
const circusCourses = [
  {
    id: 'cirkusova-skolicka',
    t: 'Cirkusová školička',
    age: '3–5 let',
    when: 'každou středu od 14:15',
    price: '4 000 Kč / semestr',
    d: 'Zkušení trenéři a akrobaté naučí děti základní pohybové dovednosti a zdolávání jednoduchých překážek — formou hry a s pomocí cirkusových vzdělávacích technik. Rodiče jsou na hodině vítáni.',
    media: 'media-sand',
    img: 'cirkusová školička',
  },
  {
    id: 'zaklady-gymnastiky',
    t: 'Základy cirkusového tréninku',
    age: '6–8 let',
    when: 'každou středu od 15:15',
    price: '4 600 Kč / semestr',
    d: 'Děti si formou hry osvojí základy gymnastiky a akrobacie. Hodina má dvě části: cvičení pro správné držení těla, koordinaci a obratnost — a jednotlivé disciplíny jako pozemní akrobacie nebo žonglování.',
    media: 'media-clay',
    img: 'základy gymnastiky a akrobacie',
  },
  {
    id: 'akrobacie-zonglovani',
    t: 'Hlavou ve vzduchu',
    age: '9–12 let',
    when: 'každou středu od 16:30',
    price: '5 500 Kč / semestr',
    d: 'Jednotlivé cirkusové disciplíny do hloubky: pozemní i závěsná akrobacie a žonglování. Ucelený soubor základních dovedností doplněný o skupinová cvičení pro spolupráci v kolektivu.',
    media: 'media-green',
    img: 'pozemní a závěsná akrobacie',
  },
];

const objevovarnaFacts = [
  'Děti do 5 let',
  'Každou středu 13:30 a 14:30 · 45 minut',
  'Max 6 dětí',
  '250 Kč / vstup',
];
---
<Layout
  title="Kroužky pro děti — BoHeMi fitness Vinohrady"
  description="Cirkusové kroužky Akademie Cirk La Putyka pro děti 3–12 let, Objevovárna pro nejmenší do 5 let a Dětská Zumba. Malé skupiny na pražských Vinohradech pod vedením zkušených lektorů a akrobatů."
>
  <Header current="/krouzky-pro-deti/" />
  <main>
    <!-- HERO -->
    <section class="relative mx-auto max-w-[1220px] overflow-hidden px-5 pb-8 pt-16 md:px-8 md:pt-20">
      <div
        class="pointer-events-none absolute right-0 top-2.5 h-[400px] w-[400px] rounded-full"
        style="background:radial-gradient(circle, rgba(226,35,26,0.12), rgba(226,35,26,0) 70%);"
        aria-hidden="true"
      ></div>
      <div class="relative">
        <p class="mb-4 text-[13px] font-extrabold uppercase tracking-[0.08em] text-accent-text">
          <a href="/lekce-a-sluzby/" class="hover:text-ink">Lekce a služby</a> · Pro děti a rodiny
        </p>
        <h1 class="text-[clamp(40px,6.2vw,76px)] font-extrabold leading-[0.98] tracking-[-0.035em]">
          Kroužky pro <span class="font-medium italic text-accent-text">děti</span>
        </h1>
        <p class="mt-6 max-w-[56ch] text-[clamp(18px,2.1vw,22px)] leading-[1.45] text-ink-warm">
          Cirkusové kroužky Akademie Cirk La Putyka, Objevovárna pro nejmenší a Dětská Zumba.
          Na Vinohradech, v malých skupinách, kde se dětem někdo věnuje.
        </p>
      </div>
    </section>

    <!-- AKADEMIE CIRK LA PUTYKA -->
    <section class="mx-auto max-w-[1220px] px-5 pt-6 md:px-8">
      <h2 class="mb-3 text-[clamp(26px,3.2vw,38px)] font-extrabold leading-[1.06] tracking-[-0.03em]">Akademie Cirk La Putyka</h2>
      <p class="mb-8 max-w-[60ch] text-[17px] leading-[1.55] text-ink-soft">
        Cirkusové kroužky vedené zkušenými trenéry a akrobaty Cirk La Putyka. Děti se učí
        pohybové dovednosti, spolupráci a vytrvalost — každá věková skupina má svůj kurz.
      </p>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {circusCourses.map((c) => (
          <div id={c.id} class="flex scroll-mt-24 flex-col overflow-hidden rounded-2xl border border-border bg-surface transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_20px_40px_-20px_rgba(33,31,26,0.24)]">
            <MediaFrame media={c.media} rounded="rounded-none" class="h-44" alt={`Kroužek — ${c.img}`} />
            <div class="flex flex-1 flex-col p-[22px]">
              <h3 class="mb-2 text-[21px] font-extrabold tracking-[-0.02em]">{c.t}</h3>
              <div class="mb-3 text-[12.5px] font-bold tracking-[0.02em] text-brand">{c.age} · {c.when}</div>
              <p class="text-[15.5px] leading-[1.5] text-ink-soft">{c.d}</p>
              <div class="mt-auto flex items-center justify-between gap-3 pt-4">
                <span class="text-[15px] font-extrabold text-ink">{c.price}</span>
                <a href={RESERVE_URL} class="cursor-pointer text-[14px] font-bold text-accent-text hover:text-ink">Přihlásit →</a>
              </div>
            </div>
          </div>
        ))}
      </div>
      <div class="mt-6 flex flex-wrap items-center justify-between gap-4 rounded-2xl border border-mint-border bg-mint px-7 py-6">
        <p class="max-w-[62ch] text-[16px] leading-[1.55] text-ink">
          <strong class="font-bold">Semestr běží 16. 9. 2026 – 27. 1. 2027,</strong> přednostní přihlášky
          na další semestr do 15. 7. 2026. Plná kapacita? Zařadíme dítě jako náhradníka nebo rovnou
          na další semestr — napiš na <a href="mailto:info@bohemi.fit" class="font-bold text-accent-text hover:text-ink">info@bohemi.fit</a>.
        </p>
        <a href="https://www.laputyka.cz/cs" rel="noopener noreferrer" target="_blank" class="shrink-0 text-[14px] font-bold text-accent-text hover:text-ink">Více o Cirk La Putyka ↗</a>
      </div>
    </section>

    <!-- OBJEVOVÁRNA -->
    <section id="objevovarna" class="mx-auto max-w-[1220px] scroll-mt-24 px-5 pt-14 md:px-8">
      <div class="grid gap-6 overflow-hidden rounded-[22px] border border-border bg-surface lg:grid-cols-[1.1fr_0.9fr]">
        <div class="p-8 md:p-10">
          <h2 class="mb-3 text-[clamp(26px,3.2vw,38px)] font-extrabold leading-[1.06] tracking-[-0.03em]">Objevovárna</h2>
          <p class="mb-5 max-w-[54ch] text-[17px] leading-[1.55] text-ink-soft">
            Nevedená hernička pro děti do 5 let — 6 stanovišť, kde děti svobodně objevují
            a zkoumají svět vlastním tempem. Aktivity se průběžně obměňují, oblíbené zůstávají.
            A je tu i místo na svačinu.
          </p>
          <ul class="mb-7 flex flex-col gap-2.5">
            {objevovarnaFacts.map((f) => (
              <li class="flex items-start gap-2.5 text-[15.5px] text-ink-line">
                <span class="mt-[7px] h-1.5 w-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
                <span>{f}</span>
              </li>
            ))}
          </ul>
          <Button href={RESERVE_URL} variant="brand">Rezervovat místo →</Button>
        </div>
        <MediaFrame media="media-rose" rounded="rounded-none" class="min-h-[240px] lg:min-h-full" alt="Objevovárna — hernička pro nejmenší" />
      </div>
    </section>

    <!-- DĚTSKÁ ZUMBA + SUPERMAMKY -->
    <section class="mx-auto max-w-[1220px] px-5 pt-14 md:px-8">
      <div class="grid gap-6 sm:grid-cols-2">
        <div id="detska-zumba" class="flex scroll-mt-24 flex-col rounded-2xl border border-border bg-surface p-8">
          <h2 class="mb-2 text-2xl font-extrabold tracking-[-0.02em]">Dětská Zumba</h2>
          <p class="mb-6 text-[15.5px] leading-[1.55] text-ink-soft">
            Taneční lekce pro děti v rytmu Zumby — zábava, koordinace a pohyb hravou formou.
            Vede Eliška Velázquez.
          </p>
          <a href={RESERVE_URL} class="mt-auto cursor-pointer self-start text-[15px] font-bold text-accent-text hover:text-ink">Rezervovat →</a>
        </div>
        <a href="/supermamky/" class="flex cursor-pointer flex-col rounded-2xl border border-border bg-surface p-8 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_20px_40px_-20px_rgba(33,31,26,0.24)]">
          <h2 class="mb-2 text-2xl font-extrabold tracking-[-0.02em]">Supermamky — pro mámy a táty</h2>
          <p class="mb-6 text-[15.5px] leading-[1.55] text-ink-soft">
            Kruhový trénink, kam můžeš přijít i s miminkem nebo batoletem — v sále jsou hračky.
            Cvičení se přizpůsobí realitě rodičovství a bere ohled na diastázu i zdravotní omezení.
          </p>
          <span class="mt-auto self-start text-[15px] font-bold text-accent-text">Detail →</span>
        </a>
      </div>
    </section>

    <!-- FINÁLNÍ CTA -->
    <section class="mx-auto max-w-[1220px] px-5 pb-16 pt-14 md:px-8 md:pb-23">
      <div class="relative flex flex-wrap items-center justify-between gap-6 overflow-hidden rounded-[22px] bg-ink-dark p-8 text-cream md:p-[clamp(32px,5vw,56px)]">
        <div
          class="pointer-events-none absolute -bottom-22 -right-12 h-[340px] w-[340px] rounded-full"
          style="background:radial-gradient(circle, rgba(226,35,26,0.18), rgba(226,35,26,0) 70%);"
          aria-hidden="true"
        ></div>
        <div class="relative">
          <h2 class="max-w-[22ch] text-[clamp(26px,3.4vw,40px)] font-extrabold tracking-[-0.03em]">Nevíš, co pro své dítě vybrat?</h2>
          <p class="mt-3 max-w-[44ch] text-[17px] text-cream-muted">Napiš nám věk a co dítě baví — doporučíme kroužek, který mu sedne.</p>
        </div>
        <a
          href="/kontakt/"
          class="relative inline-flex shrink-0 cursor-pointer items-center gap-2 rounded-full bg-accent-text px-7 py-3.5 text-[17px] font-bold text-cream transition-colors hover:bg-accent-deep"
        >
          Napsat nám →
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
