---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';

const highlights = [
  { stat: '100 m²', d: 'Celý sál jen pro vás. Žádní cizí lidé, žádný hluk, žádné čekání.' },
  { stat: 'Max 5', d: 'Maximálně 5 lidí na jednu rezervaci — ideální pro skupinový trénink nebo partu kamarádů.' },
  { stat: '60 min', d: 'Hodinové bloky — dost času na rozcvičení, trénink i protažení bez stresu.' },
];

const equipment = [
  'Kettlebells (různé hmotnosti)',
  'TRX závěsný systém',
  'Odporové gumy',
  'Podlahové matrace',
  'Příslušenství pro funkční trénink',
];
---
<Layout
  title="Open Gym — BoHeMi fitness Vinohrady"
  description="Privátní sál 100 m² jen pro tebe nebo malou skupinu. Kettlebells, TRX, odporové gumy — Open Gym v BoHeMi na pražských Vinohradech."
>
  <Header current="/open-gym/" />
  <main>
    <section class="relative mx-auto max-w-[1220px] overflow-hidden px-5 pb-10 pt-16 md:px-8 md:pt-20">
      <div
        class="pointer-events-none absolute right-0 top-2.5 h-[400px] w-[400px] rounded-full"
        style="background:radial-gradient(circle, rgba(226,35,26,0.12), rgba(226,35,26,0) 70%);"
        aria-hidden="true"
      ></div>
      <div class="relative">
        <p class="mb-4 text-[13px] font-extrabold uppercase tracking-[0.08em] text-accent-text">
          <a href="/lekce-a-sluzby/" class="hover:text-ink">Lekce a služby</a> · Individuální služby
        </p>
        <h1 class="text-[clamp(40px,6.2vw,76px)] font-extrabold leading-[0.98] tracking-[-0.035em]">
          Open <span class="font-medium text-accent-text">Gym</span>
        </h1>
        <p class="mt-6 max-w-[56ch] text-[clamp(18px,2.1vw,22px)] leading-[1.45] text-ink-warm">
          Privátní sál 100 m² jen pro tebe nebo malou skupinu. Cvičíš sám nebo s partou — bez davu, bez čekání.
        </p>
        <div class="mt-8 flex flex-wrap gap-3.5">
          <Button href="https://bohemi.fit/rezervace/" variant="primary">Rezervovat Open Gym →</Button>
          <Button href="/kontakt/" variant="outline">Zeptat se na podrobnosti</Button>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-[1220px] px-5 py-8 md:px-8">
      <div class="grid gap-5 sm:grid-cols-3">
        {highlights.map((h) => (
          <div class="rounded-2xl border border-border bg-surface p-7">
            <div class="mb-2 text-[34px] font-extrabold text-accent-text">{h.stat}</div>
            <p class="text-[15.5px] text-ink-soft">{h.d}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="mx-auto max-w-[1220px] px-5 py-6 md:px-8">
      <h2 class="mb-6 text-2xl font-extrabold tracking-[-0.02em]">Vybavení</h2>
      <ul class="grid gap-3 sm:grid-cols-2 md:grid-cols-3">
        {equipment.map((e) => (
          <li class="flex items-start gap-3 text-[16px] text-ink-soft">
            <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
            {e}
          </li>
        ))}
      </ul>
    </section>

    <section class="mx-auto max-w-[1220px] px-5 py-6 md:px-8">
      <h2 class="mb-6 text-2xl font-extrabold tracking-[-0.02em]">Dostupné termíny</h2>
      <p class="mb-6 max-w-[52ch] text-[16px] text-ink-soft">
        Open Gym je k dispozici pondělí až čtvrtek. Aktuální dostupnost a rezervace online.
      </p>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-2xl border border-border bg-surface p-5">
          <div class="mb-3 text-[13px] font-extrabold uppercase tracking-[0.06em] text-accent-text">Pondělí</div>
          <ul class="flex flex-col gap-1.5 text-[15px] text-ink-soft">
            <li>15:00 – 16:00</li>
            <li>18:30 – 19:30</li>
          </ul>
        </div>
        <div class="rounded-2xl border border-border bg-surface p-5">
          <div class="mb-3 text-[13px] font-extrabold uppercase tracking-[0.06em] text-accent-text">Úterý</div>
          <ul class="flex flex-col gap-1.5 text-[15px] text-ink-soft">
            <li>14:00 – 16:00</li>
            <li>19:30 – 21:30</li>
          </ul>
        </div>
        <div class="rounded-2xl border border-border bg-surface p-5">
          <div class="mb-3 text-[13px] font-extrabold uppercase tracking-[0.06em] text-accent-text">Středa</div>
          <ul class="flex flex-col gap-1.5 text-[15px] text-ink-soft">
            <li>19:00 – 21:00</li>
          </ul>
        </div>
        <div class="rounded-2xl border border-border bg-surface p-5">
          <div class="mb-3 text-[13px] font-extrabold uppercase tracking-[0.06em] text-accent-text">Čtvrtek</div>
          <ul class="flex flex-col gap-1.5 text-[15px] text-ink-soft">
            <li>14:00 – 16:00</li>
            <li>19:30 – 21:30</li>
          </ul>
        </div>
      </div>
      <div class="mt-6">
        <Button href="https://bohemi.fit/rezervace/" variant="brand">Zobrazit termíny →</Button>
      </div>
    </section>

    <section class="mx-auto max-w-[1220px] px-5 pb-16 pt-10 md:px-8 md:pb-23">
      <div class="relative flex flex-wrap items-center justify-between gap-6 overflow-hidden rounded-[22px] bg-ink-dark p-8 text-cream md:p-[clamp(32px,5vw,56px)]">
        <div
          class="pointer-events-none absolute -bottom-22 -right-12 h-[340px] w-[340px] rounded-full"
          style="background:radial-gradient(circle, rgba(226,35,26,0.18), rgba(226,35,26,0) 70%);"
          aria-hidden="true"
        ></div>
        <div class="relative">
          <h2 class="max-w-[22ch] text-[clamp(26px,3.4vw,40px)] font-extrabold tracking-[-0.03em]">Chceš mít sál jen pro sebe?</h2>
          <p class="mt-3 max-w-[42ch] text-[17px] text-cream-muted">Rezervuj si slot přímo nebo nám napiš — poradíme s termínem i programem tréninku.</p>
        </div>
        <a
          href="https://bohemi.fit/rezervace/"
          class="relative inline-flex shrink-0 cursor-pointer items-center gap-2 rounded-full bg-accent-text px-7 py-3.5 text-[17px] font-bold text-cream transition-colors hover:bg-accent-deep"
        >
          Rezervovat Open Gym →
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
