---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import MediaFrame from '../components/MediaFrame.astro';
import { RESERVE_URL } from '../data/home';

// Detail vlajkového programu. Obsahové zdroje: fraze-pool.md (fráze použité
// tady se NESMÍ opakovat na homepage — HP drží jen slogan „Neber nic jako
// svaté"). Osnova 8 témat potvrzena Honzou 7/2026 — je to PLÁN programu.

const weekRhythm = [
  { t: '2× vedený trénink', d: 'Kruhový nebo silový trénink v malé skupině. Trenér tě zná, opraví techniku a nastaví zátěž podle tvé úrovně.' },
  { t: '1× praktický blok', d: 'Zhruba 20 minut na jedno téma týdne — spánek, jídlo, dech… Konkrétní věci k vyzkoušení, žádná přednáška.' },
  { t: 'Deník návyků', d: 'Jedna otázka denně, dvě minuty času. Aby bylo na konci vidět, co se změnilo — ne jen pocit, že „to bylo fajn".' },
];

// 8 témat = přeložený program péče o tělo (pohyb → spánek → jídlo → dech →
// držení těla → režim), věcně a měřitelně. Témata 4 a 5 držet striktně
// fyziologicky (rozhodnutí Honzy) — nerozvíjet do konceptů.
const weeks = [
  { n: '01', t: 'Kde jsi teď', d: 'Vstupní měření síly, kondice, mobility a režimu. Ne kvůli známce — kvůli srovnání, až přijde týden 8.' },
  { n: '02', t: 'Pohyb jako standard', d: 'Jak si postavit týden, aby pohyb nevypadl, když přijde práce, děti, stres nebo plný diář. Pravidelnost má přednost před intenzitou.' },
  { n: '03', t: 'Spánek', d: 'Spánek není lenost — je to část tréninku, ve které tělo opravuje, třídí a obnovuje síly. Co pro něj jde udělat prakticky.' },
  { n: '04', t: 'Jídlo a voda', d: 'Jez, když máš hlad. Přestaň, když jsi najedený. Bez dietní hysterie — sleduješ, po kterém jídle jsi lehký a po kterém padáš. Žádné tabulky kalorií.' },
  { n: '05', t: 'Dech', d: 'Tři minuty klidného dýchání denně. Tempo dechu měřitelně ovlivňuje tep a reakci na stres — žádná meditace, jen nástroj, který máš pořád u sebe.' },
  { n: '06', t: 'Držení těla a technika', d: 'Sed, stoj, zvedání, dřep, tah. Co se naučíš v sále, přeneseš do běžného dne — v práci, doma, při nošení nákupu.' },
  { n: '07', t: 'Rytmus', d: 'Zdraví se nedělá nárazem, dělá se rytmem — opakováním malých věcí, které zvládneš i v horším týdnu. Co vydrží, si necháš.' },
  { n: '08', t: 'Kde jsi teď — podruhé', d: 'Závěrečné měření stejných položek jako v týdnu 1, porovnání a plán, jak pokračovat bez programu. Posun uvidíš v číslech, ne v dojmech.' },
];

// Položky měření dle Honzových podkladů (7/2026) — plný protokol testů je
// interně v docs/program-8-tydnu-podklady.md, web nese jen srozumitelný souhrn.
const measures = [
  { t: 'Síla', d: 'Dřep, klik, výdrž ve vzporu a nošení zátěže. Počítají se kvalitní opakování, ne rekordy — každý cvik má variantu pro tvou úroveň.' },
  { t: 'Kondice', d: 'Tři minuty mírné zátěže a sledování, jak rychle se zklidní dech. Námahu hodnotíš na škále 1–10 — žádné medicínské testy.' },
  { t: 'Mobilita a držení těla', d: 'Dřep, předklon, ramena, zvednutí ze země. Zapisujeme slovně — bez potíží, lehké omezení, výrazné omezení. Ne známkou.' },
  { t: 'Režim a návyky', d: 'Krátký dotazník: spánek, energie během dne, pohyb mimo lekce, jídlo, voda, dech a dotahování věcí, které začneš.' },
];

const signs = ['Vstaneš svěží', 'Po jídle ti není těžko', 'Spíš tvrdě', 'Zvládneš zátěž'];

const forYou = [
  'Začínáš, nebo se vracíš po dlouhé pauze.',
  'Chceš strukturu, termíny a skupinu — ne jen odhodlání.',
  'Nechceš si trénink a návyky skládat sám/sama.',
];
const notForYou = [
  'Čekáš zázračné hubnutí za dva měsíce — slibujeme posun, ne zázrak.',
  'Řešíš zranění nebo léčbu — program nenahrazuje lékařskou ani rehabilitační péči.',
  'Chceš cvičit jen občas a bez závazku — na to jsou skupinové lekce.',
];

// FAQ: podmínky náhrad a ukončení dle Honzova rozhodnutí 7/2026 — finální
// právní znění patří do VOP (LEGAL stránky), tady je srozumitelný souhrn.
const faq: { q: string; a: string }[] = [
  { q: 'Co když jednu lekci nestihnu?', a: 'Jednotlivé absence můžeš nahradit na běžných skupinových lekcích BoHeMi — maximálně 2 lekce během jednoho běhu programu. Nevyužité lekce se po skončení programu neproplácí.' },
  { q: 'Co když vypadnu v půlce programu?', a: 'Účast se hradí předem a místo je rezervované na celý běh. Pokud po prvním týdnu zjistíš, že program pro tebe není, můžeš skončit a vrátíme ti 70 % ceny. Při pozdějším ukončení se kurzovné nevrací. Výjimka je nemoc nebo úraz doložený lékařem — nevyčerpanou část převedeme do dalšího běhu, případně vyřešíme kreditem po domluvě.' },
  { q: 'Musím být fit předem?', a: 'Ne. Každý cvik má lehčí i těžší variantu a trenér ti nastaví zátěž podle tvé úrovně. Program je stavěný pro začátek a návrat k pohybu, ne pro závodníky.' },
  { q: 'Co obnáší deník návyků?', a: 'Jedna otázka denně, dvě minuty času. Večer si odpovíš, jestli ses dnes hýbal/a, jak se spalo a jak ti bylo po jídle. Žádné tabulky, žádná aplikace navíc.' },
];
---
<Layout
  title="Program 8 týdnů — BoHeMi fitness Vinohrady"
  description="Vlajkový program BoHeMi: 8 týdnů, 2× týdně vedený trénink v uzavřené skupině do 12 lidí, praktické bloky o spánku, jídle a režimu, měření na začátku i na konci."
>
  <Header current="/program-8-tydnu/" />
  <main>
    <!-- HERO -->
    <section class="relative mx-auto max-w-[1220px] overflow-hidden px-5 pb-8 pt-16 md:px-8 md:pt-20">
      <div
        class="pointer-events-none absolute right-0 top-2.5 h-[400px] w-[400px] rounded-full"
        style="background:radial-gradient(circle, rgba(226,35,26,0.12), rgba(226,35,26,0) 70%);"
        aria-hidden="true"
      ></div>
      <div class="relative max-w-[760px]">
        <p class="mb-4 text-[13px] font-extrabold uppercase tracking-[0.08em] text-accent-text">
          <a href="/lekce-a-sluzby/" class="hover:text-ink">Lekce a služby</a> · Pro tebe · Vlajkový program
        </p>
        <h1 class="text-[clamp(40px,6.2vw,76px)] font-extrabold leading-[0.98] tracking-[-0.035em]">
          Program <span class="font-medium italic text-accent-text">8 týdnů</span>
        </h1>
        <p class="mt-6 max-w-[58ch] text-[clamp(18px,2.1vw,22px)] leading-[1.45] text-ink-warm">
          Osm týdnů, dva vedené tréninky týdně a jeden praktický blok. Uzavřená skupina
          do 12 lidí, měření na začátku a na konci.
        </p>
        <p class="mt-4 max-w-[58ch] text-[16.5px] leading-[1.55] text-ink-soft">
          Není to kurz o tom, jak se změnit přes noc — ani terapie, dieta nebo osobní rozvoj.
          Je to osm týdnů obyčejné praxe, při které si na vlastním těle ověříš, co ti pomáhá fungovat líp.
        </p>
      </div>
    </section>

    <!-- JAK TÝDEN VYPADÁ -->
    <section class="mx-auto max-w-[1220px] px-5 pt-6 md:px-8">
      <div class="grid gap-6 overflow-hidden rounded-[22px] border border-border bg-surface lg:grid-cols-[1.1fr_0.9fr]">
        <div class="p-8 md:p-10">
          <h2 class="mb-3 text-[clamp(26px,3.2vw,38px)] font-extrabold leading-[1.06] tracking-[-0.03em]">Jak vypadá jeden týden</h2>
          <p class="mb-6 max-w-[54ch] text-[17px] leading-[1.55] text-ink-soft">
            Každý týden má stejný rytmus, jen jiné téma. Skupina jde programem společně
            od prvního do posledního dne — nikdo nenastupuje v půlce.
          </p>
          <ul class="flex flex-col gap-5">
            {weekRhythm.map((r) => (
              <li class="flex items-start gap-3.5">
                <span class="mt-[8px] h-1.5 w-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
                <div>
                  <h3 class="text-[18px] font-extrabold tracking-[-0.02em]">{r.t}</h3>
                  <p class="text-[15.5px] leading-[1.5] text-ink-soft">{r.d}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>
        <MediaFrame media="media-clay" rounded="rounded-none" class="min-h-[240px] lg:min-h-full" alt="Skupina Programu 8 týdnů při vedeném tréninku" />
      </div>
    </section>

    <!-- 8 TÉMAT -->
    <section class="mx-auto max-w-[1220px] px-5 pt-14 md:px-8">
      <h2 class="mb-3 text-[clamp(26px,3.2vw,38px)] font-extrabold leading-[1.06] tracking-[-0.03em]">8 týdnů, 8 témat</h2>
      <p class="mb-8 max-w-[58ch] text-[17px] leading-[1.55] text-ink-soft">
        Tréninky drží tělo, praktické bloky drží zbytek. Každý týden jedno téma —
        konkrétní, vyzkoušitelné a dost malé na to, aby vydrželo i po programu.
      </p>
      <div class="grid gap-5 sm:grid-cols-2">
        {weeks.map((w) => (
          <div class="relative overflow-hidden rounded-2xl border border-border bg-surface p-7">
            <span class="pointer-events-none absolute -right-1.5 -top-2.5 text-[64px] italic text-ink-ghost" aria-hidden="true">{w.n}</span>
            <h3 class="relative mb-2 max-w-[85%] text-[21px] font-extrabold tracking-[-0.02em]">{w.t}</h3>
            <p class="relative text-[15.5px] leading-[1.5] text-ink-soft">{w.d}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- PULL-QUOTE -->
    <section class="mx-auto max-w-[1220px] px-5 pt-14 md:px-8">
      <figure class="relative overflow-hidden rounded-[22px] bg-ink-dark px-8 py-12 text-center md:px-12 md:py-16">
        <div
          class="pointer-events-none absolute -left-16 -top-16 h-[300px] w-[300px] rounded-full"
          style="background:radial-gradient(circle, rgba(226,35,26,0.16), rgba(226,35,26,0) 70%);"
          aria-hidden="true"
        ></div>
        <blockquote class="relative mx-auto max-w-[26ch] text-[clamp(24px,3.4vw,40px)] font-medium italic leading-[1.15] tracking-[-0.02em] text-cream">
          „Nejlepší trénink je někdy ten, že na pár dní přestaneš tělu škodit."
        </blockquote>
      </figure>
    </section>

    <!-- CO SE MĚŘÍ -->
    <section class="mx-auto max-w-[1220px] px-5 pt-14 md:px-8">
      <h2 class="mb-3 text-[clamp(26px,3.2vw,38px)] font-extrabold leading-[1.06] tracking-[-0.03em]">Co se měří</h2>
      <p class="mb-8 max-w-[58ch] text-[17px] leading-[1.55] text-ink-soft">
        Nejde o známkování, porovnávání ani soutěž. Chceme vědět, kde právě jsi, abychom se
        v týdnu 8 mohli podívat, co se změnilo. Žádný výkonový test — výchozí bod a srovnání.
      </p>
      <div class="grid gap-5 sm:grid-cols-2">
        {measures.map((m) => (
          <div class="rounded-2xl border border-border bg-surface p-7">
            <h3 class="mb-2 text-[21px] font-extrabold tracking-[-0.02em]">{m.t}</h3>
            <p class="text-[15.5px] leading-[1.5] text-ink-soft">{m.d}</p>
          </div>
        ))}
      </div>
      <p class="mt-6 max-w-[58ch] text-[15.5px] leading-[1.55] text-ink-soft">
        K tomu pár osobních otázek: co tě v těle nejvíc omezuje, co ti bere nejvíc energie
        a jak se chceš po osmi týdnech cítit. V týdnu 8 to celé zopakujeme — cílem není dokonalý
        výsledek, ale jasnější odpověď na otázku, co ti funguje a jak v tom pokračovat dál.
      </p>
    </section>

    <!-- JAK POZNÁŠ, ŽE TO FUNGUJE -->
    <section class="mx-auto max-w-[1220px] px-5 pt-14 md:px-8">
      <div class="rounded-[22px] border border-border bg-surface p-8 md:p-10">
        <h2 class="mb-3 text-[clamp(26px,3.2vw,38px)] font-extrabold leading-[1.06] tracking-[-0.03em]">Jak poznáš, že to funguje</h2>
        <p class="mb-6 max-w-[54ch] text-[17px] leading-[1.55] text-ink-soft">
          Zdraví se nehádá, pozná se. To nejsou pocity — to jsou znaky:
        </p>
        <ul class="grid gap-4 sm:grid-cols-2">
          {signs.map((s) => (
            <li class="flex items-start gap-3.5 text-[17px] font-bold text-ink-line">
              <span class="mt-0.5 flex h-[22px] w-[22px] shrink-0 items-center justify-center rounded-full bg-accent/12 text-[13px] font-extrabold text-accent-text" aria-hidden="true">✓</span>
              <span>{s}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- PRO KOHO JE / NENÍ -->
    <section class="mx-auto max-w-[1220px] px-5 pt-14 md:px-8">
      <div class="grid gap-5 md:grid-cols-2">
        <div class="rounded-[22px] border border-border bg-surface p-8">
          <h2 class="mb-5 text-[clamp(22px,2.6vw,30px)] font-extrabold tracking-[-0.03em]">Pro koho to je</h2>
          <ul class="flex flex-col gap-3.5">
            {forYou.map((item) => (
              <li class="flex items-start gap-2.5 text-[16px] leading-[1.5] text-ink-line">
                <span class="mt-[8px] h-1.5 w-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="rounded-[22px] border border-border bg-mint p-8">
          <h2 class="mb-5 text-[clamp(22px,2.6vw,30px)] font-extrabold tracking-[-0.03em]">Pro koho to není</h2>
          <ul class="flex flex-col gap-3.5">
            {notForYou.map((item) => (
              <li class="flex items-start gap-2.5 text-[16px] leading-[1.5] text-ink-line">
                <span class="mt-[8px] h-1.5 w-1.5 shrink-0 rounded-full bg-brand" aria-hidden="true"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
          <p class="mt-5 text-[15px]">
            <a href="/skupinove-lekce/" class="cursor-pointer font-bold text-accent-text hover:text-ink">Podívat se na skupinové lekce →</a>
          </p>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="mx-auto max-w-[1220px] px-5 pt-14 md:px-8">
      <h2 class="mb-7 text-[clamp(26px,3.2vw,38px)] font-extrabold leading-[1.06] tracking-[-0.03em]">Časté otázky</h2>
      <div class="flex max-w-[860px] flex-col gap-3.5">
        {faq.map((f) => (
          <details class="group rounded-2xl border border-border bg-surface px-6 py-1">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-4 text-[17px] font-extrabold tracking-[-0.01em] [&::-webkit-details-marker]:hidden">
              {f.q}
              <svg class="h-5 w-5 shrink-0 text-accent-text transition-transform duration-200 group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="m6 9 6 6 6-6" />
              </svg>
            </summary>
            <p class="pb-5 text-[15.5px] leading-[1.55] text-ink-soft">{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="mx-auto max-w-[1220px] px-5 pb-16 pt-14 md:px-8 md:pb-23">
      <div class="relative overflow-hidden rounded-[22px] bg-ink-dark p-8 text-cream md:p-[clamp(32px,5vw,56px)]">
        <div
          class="pointer-events-none absolute -bottom-22 -right-12 h-[340px] w-[340px] rounded-full"
          style="background:radial-gradient(circle, rgba(226,35,26,0.18), rgba(226,35,26,0) 70%);"
          aria-hidden="true"
        ></div>
        <div class="relative flex flex-wrap items-center justify-between gap-6">
          <div>
            <h2 class="max-w-[24ch] text-[clamp(26px,3.4vw,40px)] font-extrabold tracking-[-0.03em]">Chceš do příští skupiny?</h2>
            <p class="mt-3 max-w-[46ch] text-[17px] text-cream-muted">
              První běh připravujeme na září 2026 — přesný termín zveřejníme po potvrzení
              rozvrhu. Cenu a podmínky najdeš
              <a href="/cenik/" class="cursor-pointer font-bold text-cream underline underline-offset-4 hover:text-cream-soft">v ceníku</a>.
            </p>
          </div>
          <div class="flex flex-col items-start gap-3.5">
            <Button href={RESERVE_URL} external variant="primary">Rezervovat místo →</Button>
            <Button href="/skupinove-lekce/" variant="outline-light" class="px-5 py-2.5 text-[15px]">Nejsi si jistý? Přijď nejdřív na jednu lekci →</Button>
          </div>
        </div>
        <p class="relative mt-7 text-[14px] text-cream-muted">Program nenahrazuje lékařskou ani rehabilitační péči.</p>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
