---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import imgStudio02 from '../assets/studio/studio-02.jpg';
import imgStudio03 from '../assets/studio/studio-03.jpg';
import imgStudio04 from '../assets/studio/studio-04.jpg';
import imgStudio05 from '../assets/studio/studio-05.jpg';
import imgStudio07 from '../assets/studio/studio-07.jpg';
import imgStudio08 from '../assets/studio/studio-08.jpg';
import imgStudio09 from '../assets/studio/studio-09.jpg';
import imgStudio10 from '../assets/studio/studio-10.jpg';
import imgStudio11 from '../assets/studio/studio-11.jpg';

const photos = [
  { src: imgStudio04, alt: 'Tým BoHeMi v sále se zrcadly' },
  { src: imgStudio02, alt: 'Tematický trénink v BoHeMi' },
  { src: imgStudio03, alt: 'Skupina cvičenců v BoHeMi' },
  { src: imgStudio07, alt: 'BoHeMi tým se čtyřnohým hostem' },
  { src: imgStudio05, alt: 'Tým BoHeMi před studiem na Vinohradech' },
  { src: imgStudio08, alt: 'Instalace vývěsního štítu BoHeMi na fasádě' },
  { src: imgStudio09, alt: 'Hudební koutek studia — bicí souprava' },
  { src: imgStudio10, alt: 'Hudební koutek studia — klávesy' },
  { src: imgStudio11, alt: 'Hudební koutek studia — celkový pohled' },
];
---
<Layout
  title="Fotky — BoHeMi fitness Vinohrady"
  description="Fotky ze studia BoHeMi fitness na pražských Vinohradech — atmosféra, tým a zázemí mimo jednotlivé lekce."
>
  <Header current="/fotky/" />
  <main>
    <!-- HERO -->
    <section class="relative mx-auto max-w-[1220px] overflow-hidden px-5 pb-8 pt-16 md:px-8 md:pt-20">
      <div
        class="pointer-events-none absolute right-0 top-2.5 h-[400px] w-[400px] rounded-full"
        style="background:radial-gradient(circle, rgba(226,35,26,0.12), rgba(226,35,26,0) 70%);"
        aria-hidden="true"
      ></div>
      <div class="relative max-w-[680px]">
        <h1 class="text-[clamp(40px,6.2vw,76px)] font-extrabold leading-[0.98] tracking-[-0.035em]">
          Fotky ze <span class="font-medium text-accent-text">studia</span>
        </h1>
        <p class="mt-6 max-w-[54ch] text-[clamp(18px,2.1vw,22px)] leading-[1.45] text-ink-warm">
          Atmosféra, tým a zázemí BoHeMi mimo jednotlivé lekce.
          Fotky konkrétních lekcí najdeš na <a href="/skupinove-lekce/" class="font-bold text-accent-text hover:text-ink">stránce lekcí</a>,
          fotky sálů k pronájmu na <a href="/pronajem-salu/" class="font-bold text-accent-text hover:text-ink">stránce pronájmu</a>.
        </p>
      </div>
    </section>

    <!-- GALERIE -->
    <section class="mx-auto max-w-[1220px] px-5 pb-16 md:px-8 md:pb-23">
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3">
        {photos.map((photo) => (
          <a href={photo.src.src} target="_blank" rel="noopener noreferrer" class="block aspect-square cursor-pointer overflow-hidden rounded-[14px] border border-border transition-opacity hover:opacity-90">
            <Image src={photo.src} alt={photo.alt} class="h-full w-full object-cover" widths={[320, 480]} sizes="(min-width: 640px) 33vw, 50vw" loading="lazy" />
          </a>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</Layout>
