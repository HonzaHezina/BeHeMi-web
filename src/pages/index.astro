---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import Marquee from '../components/Marquee.astro';
import ApproachGrid from '../components/ApproachGrid.astro';
import Offer from '../components/Offer.astro';
import LifePracticeFeature from '../components/LifePracticeFeature.astro';
import ProcTeaser from '../components/ProcTeaser.astro';
import TriadVenn from '../components/TriadVenn.astro';
import Audiences from '../components/Audiences.astro';
import Trainers from '../components/Trainers.astro';
import HealthTracker from '../components/HealthTracker.astro';
import PricingTeaser from '../components/PricingTeaser.astro';
---
<Layout
  title="BoHeMi — malé skupinové tréninky na Vinohradech"
  description="BoHeMi je malé fitko na pražských Vinohradech. Skupinové tréninky, kde tě trenér opravdu zná — zpevnění těla, kondice, správný režim. Začni jednou lekcí."
>
  <Header current="/" />
  <main>
    <Hero />
    <Marquee />
    <ApproachGrid />
    <section class="mx-auto max-w-[1220px] px-5 py-16 md:px-8 md:py-20">
      <h2 class="mb-5 text-[clamp(26px,3.2vw,38px)] font-extrabold leading-[1.06] tracking-[-0.03em]">Jak se u&nbsp;n&aacute;s cvi&ccaron;&iacute;</h2>
      <p class="mb-8 max-w-[60ch] text-[18px] leading-[1.55] text-ink-warm">BoHeMi jsou 3&nbsp;s&aacute;ly na pra&zaron;sk&yacute;ch Vinohradech zaměřen&eacute; na veden&eacute; lekce, kruhovsk&eacute; tr&eacute;ninky a&nbsp;funk&ccaron;n&iacute; pohyb. &Zaron;&aacute;dn&eacute; velk&eacute; stroje, &zaron;&aacute;dn&eacute; slo&zaron;it&eacute; programy &mdash; jen pohyb, kter&yacute; funguje.</p>
      <ul class="flex flex-col gap-4">
        <li class="flex items-start gap-3.5 text-[17px] leading-[1.5] text-ink-line">
          <span class="mt-0.5 flex h-[22px] w-[22px] shrink-0 items-center justify-center rounded-full bg-accent/12 text-[13px] font-extrabold text-accent-text" aria-hidden="true">&#10003;</span>
          <span><strong class="font-bold text-ink">Mal&eacute; skupiny do&nbsp;12&nbsp;lid&iacute;</strong> &mdash; tren&eacute;r t&ecaron; opravdu vid&iacute; a oprav&iacute; techniku</span>
        </li>
        <li class="flex items-start gap-3.5 text-[17px] leading-[1.5] text-ink-line">
          <span class="mt-0.5 flex h-[22px] w-[22px] shrink-0 items-center justify-center rounded-full bg-accent/12 text-[13px] font-extrabold text-accent-text" aria-hidden="true">&#10003;</span>
          <span>Cvi&ccaron;&iacute;&scaron; s vlastn&iacute; vahou, TRX, kettlebells a dal&scaron;&iacute;mi pom&ocirc;ckami &mdash; bez stroj&ocirc;</span>
        </li>
        <li class="flex items-start gap-3.5 text-[17px] leading-[1.5] text-ink-line">
          <span class="mt-0.5 flex h-[22px] w-[22px] shrink-0 items-center justify-center rounded-full bg-accent/12 text-[13px] font-extrabold text-accent-text" aria-hidden="true">&#10003;</span>
          <span>Ka&zaron;d&aacute; lekce m&aacute; jasnou strukturu: warm-up, hlavn&iacute; trénink, cool-down</span>
        </li>
        <li class="flex items-start gap-3.5 text-[17px] leading-[1.5] text-ink-line">
          <span class="mt-0.5 flex h-[22px] w-[22px] shrink-0 items-center justify-center rounded-full bg-accent/12 text-[13px] font-extrabold text-accent-text" aria-hidden="true">&#10003;</span>
          <span>Obt&iacute;&zaron;nost se p&rcaron;izp&ocirc;sob&iacute; tv&eacute; &uacute;rovni &mdash; nemus&iacute;&scaron; se b&aacute;t za&ccaron;&aacute;tku</span>
        </li>
        <li class="flex items-start gap-3.5 text-[17px] leading-[1.5] text-ink-line">
          <span class="mt-0.5 flex h-[22px] w-[22px] shrink-0 items-center justify-center rounded-full bg-accent/12 text-[13px] font-extrabold text-accent-text" aria-hidden="true">&#10003;</span>
          <span>Progresivn&iacute; p&rcaron;&iacute;stup: postupně p&rcaron;id&aacute;v&aacute;me n&aacute;ro&ccaron;nost, ne najednou</span>
        </li>
      </ul>
    </section>
    <Offer />
    <LifePracticeFeature />
    <ProcTeaser />
    <TriadVenn />
    <Audiences />
    <Trainers />
    <HealthTracker />
    <PricingTeaser />
  </main>
  <Footer />
</Layout>
