---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/Hero.astro";
import Marquee from "../components/Marquee.astro";
import ApproachGrid from "../components/ApproachGrid.astro";
import KidsBand from "../components/KidsBand.astro";
import Offer from "../components/Offer.astro";
import LifePracticeFeature from "../components/LifePracticeFeature.astro";
import ProcTeaser from "../components/ProcTeaser.astro";
import TriadVenn from "../components/TriadVenn.astro";
import Audiences from "../components/Audiences.astro";
import Trainers from "../components/Trainers.astro";
import PricingTeaser from "../components/PricingTeaser.astro";
---
<Layout
  title="BoHeMi — malé skupinové tréninky na Vinohradech"
  description="BoHeMi je malé fitko na pražských Vinohradech. Skupinové tréninky, kde tě trenér opravdu zná — zpevnění těla, kondice, správný režim. Začni jednou lekcí."
>
  <Header current="/" />
  <main>
    <Hero />
    <Marquee />
    <ApproachGrid />
    <KidsBand />
    <section class="mx-auto max-w-[1220px] px-5 py-16 md:px-8 md:py-20">
      <h2 class="mb-5 text-[clamp(26px,3.2vw,38px)] font-extrabold leading-[1.06] tracking-[-0.03em]">Jak se u nás cvičí</h2>
      <p class="mb-8 max-w-[60ch] text-[18px] leading-[1.55] text-ink-warm">BoHeMi je fitness studio zaměřené na vedené lekce, kruhové tréninky a funkční pohyb. Žádné velké stroje, žádné složité programy — jen pohyb, který funguje. Najdeš nás na pražských Vinohradech.</p>
      <ul class="flex flex-col gap-4">
        <li class="flex items-start gap-3.5 text-[17px] leading-[1.5] text-ink-line">
          <span class="mt-0.5 flex h-[22px] w-[22px] shrink-0 items-center justify-center rounded-full bg-accent/12 text-[13px] font-extrabold text-accent-text" aria-hidden="true">✓</span>
          <span><strong class="font-bold text-ink">Malé skupiny do 12 lidí</strong> — trenér tě zná a opraví techniku</span>
        </li>
        <li class="flex items-start gap-3.5 text-[17px] leading-[1.5] text-ink-line">
          <span class="mt-0.5 flex h-[22px] w-[22px] shrink-0 items-center justify-center rounded-full bg-accent/12 text-[13px] font-extrabold text-accent-text" aria-hidden="true">✓</span>
          <span>Cvičíš s vlastní vahou, TRX, kettlebells a dalšími pomůckami — bez strojů</span>
        </li>
        <li class="flex items-start gap-3.5 text-[17px] leading-[1.5] text-ink-line">
          <span class="mt-0.5 flex h-[22px] w-[22px] shrink-0 items-center justify-center rounded-full bg-accent/12 text-[13px] font-extrabold text-accent-text" aria-hidden="true">✓</span>
          <span>Každá lekce má jasnou strukturu: warm-up, hlavní trénink, cool-down</span>
        </li>
        <li class="flex items-start gap-3.5 text-[17px] leading-[1.5] text-ink-line">
          <span class="mt-0.5 flex h-[22px] w-[22px] shrink-0 items-center justify-center rounded-full bg-accent/12 text-[13px] font-extrabold text-accent-text" aria-hidden="true">✓</span>
          <span>Obtížnost se přizpůsobí tvé úrovni — nemusíš se bát začátku</span>
        </li>
        <li class="flex items-start gap-3.5 text-[17px] leading-[1.5] text-ink-line">
          <span class="mt-0.5 flex h-[22px] w-[22px] shrink-0 items-center justify-center rounded-full bg-accent/12 text-[13px] font-extrabold text-accent-text" aria-hidden="true">✓</span>
          <span>Progresivní přístup: postupně přidáváme náročnost, ne najednou</span>
        </li>
      </ul>
    </section>
    <Offer />
    <LifePracticeFeature />
    <ProcTeaser />
    <TriadVenn />
    <Audiences />
    <Trainers />
    <PricingTeaser />
  </main>
  <Footer />
</Layout>
