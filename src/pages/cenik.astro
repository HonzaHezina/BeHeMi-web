---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import { pricing } from '../data/home';

// Ceník přebírá stejné varianty jako ceník teaser na homepage.
const priceNotes = [
  'Multisport, Benefit plus, Edenred i Sodexo (mimo vybrané lekce).',
  'Rádi vystavíme fakturu pro zaměstnavatele i čerpání z FKSP.',
  'Členství platí na kruhové, silové, Supermamky, HIIT a vlastní váhu.',
  'Pronájem sálů je hodinový při smlouvě min. na 6 měsíců.',
];
---
<Layout
  title="Ceník — za kolik to máme | BoHeMi"
  description="Ceník BoHeMi: jednorázový vstup, členství i Program 8 týdnů. Předplatné se vyplatí už při třetí lekci v týdnu. Multisport a benefity přijímáme."
>
  <Header current="/cenik/" />
  <main>
    <!-- HERO -->
    <section class="mx-auto max-w-[1220px] px-5 pb-12 pt-16 md:px-8 md:pt-20">
      <h1 class="text-[clamp(40px,6.2vw,76px)] font-extrabold leading-[0.98] tracking-[-0.035em]">
        Za kolik to <span class="font-medium italic text-accent-text">máme</span>
      </h1>
      <p class="mt-6 max-w-[54ch] text-[clamp(18px,2.1vw,22px)] leading-[1.45] text-ink-warm">
        Členství, jednotlivé vstupy i celá cesta. Vyber si podle toho, jak hluboko do toho chceš jít.
      </p>
    </section>

    <!-- CENOVÉ KARTY -->
    <section class="mx-auto max-w-[1220px] px-5 pb-6 md:px-8">
      <div class="grid gap-[22px] md:grid-cols-3">
        {pricing.map((pl) => (
          <div class={`relative flex flex-col rounded-[20px] border bg-surface px-8 py-9 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_22px_44px_-20px_rgba(33,31,26,0.24)] ${pl.featured ? 'border-2 border-accent' : 'border-border'}`}>
            {pl.badge && (
              <span class="absolute -top-2.5 left-8 rounded-full bg-accent-text px-3.5 py-1.5 text-xs font-bold uppercase tracking-[0.04em] text-cream">{pl.badge}</span>
            )}
            <h2 class="mb-1 text-2xl font-extrabold tracking-[-0.02em]">{pl.t}</h2>
            <p class="mb-[18px] text-[15px] text-ink-muted">{pl.d}</p>
            <div class="mb-1.5 flex items-baseline gap-1.5">
              <span class="text-[38px] font-extrabold tracking-[-0.02em]">{pl.price}</span>
              <span class="text-[15px] text-ink-muted">{pl.per}</span>
            </div>
            <p class="mb-[18px] min-h-[18px] text-[13.5px] font-semibold text-accent-text">{pl.note}</p>
            <ul class="mb-7 flex flex-col gap-3">
              {pl.feat.map((f) => (
                <li class="flex items-start gap-2.5 text-[15.5px] text-ink-line">
                  <span class="mt-[7px] h-1.5 w-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
                  <span>{f}</span>
                </li>
              ))}
            </ul>
            <Button href="/kontakt/" variant="dark" class="mt-auto px-[22px] py-3 text-[15.5px]">Vybrat</Button>
          </div>
        ))}
      </div>
    </section>

    <!-- POČÍTÁŠ TO? (tmavý blok s pruhy) -->
    <section class="mx-auto max-w-[1220px] px-5 pb-2 pt-10 md:px-8">
      <div class="relative overflow-hidden rounded-[20px] bg-ink-dark p-8 text-cream md:p-[clamp(32px,5vw,52px)]">
        <div
          class="pointer-events-none absolute -right-16 -top-20 h-[360px] w-[360px] rounded-full"
          style="background:radial-gradient(circle, rgba(226,35,26,0.16), rgba(226,35,26,0) 70%);"
          aria-hidden="true"
        >
        </div>
        <p class="relative mb-2 italic text-[23px] text-sage">Počítáš to?</p>
        <h2 class="relative mb-9 max-w-[22ch] text-[clamp(26px,3.4vw,40px)] font-extrabold tracking-[-0.03em]">Roční členství vychází na 150 Kč za lekci.</h2>

        <div class="relative flex max-w-[760px] flex-col gap-[26px]">
          <div>
            <div class="mb-2.5 flex items-baseline justify-between">
              <span class="text-base font-semibold text-cream-soft">Jednorázový vstup</span>
              <span class="text-xl font-extrabold">199 Kč <span class="text-sm font-medium text-cream-muted">/ lekce</span></span>
            </div>
            <div class="h-3.5 overflow-hidden rounded-full bg-border-dark">
              <div class="h-full w-full rounded-full bg-accent"></div>
            </div>
          </div>
          <div>
            <div class="mb-2.5 flex items-baseline justify-between">
              <span class="text-base font-semibold text-cream">Měsíční členství (8 lekcí)</span>
              <span class="text-xl font-extrabold text-sage">~187 Kč <span class="text-sm font-medium text-cream-muted">/ lekce</span></span>
            </div>
            <div class="h-3.5 overflow-hidden rounded-full bg-border-dark">
              <div class="h-full w-[94%] rounded-full bg-sage"></div>
            </div>
          </div>
          <div>
            <div class="mb-2.5 flex items-baseline justify-between">
              <span class="text-base font-semibold text-clay-soft">Roční členství (96 lekcí)</span>
              <span class="text-xl font-extrabold text-clay-soft">~150 Kč <span class="text-sm font-medium text-cream-muted">/ lekce</span></span>
            </div>
            <div class="h-3.5 overflow-hidden rounded-full bg-border-dark">
              <div class="h-full w-[75%] rounded-full bg-clay-soft"></div>
            </div>
          </div>
        </div>

        <p class="relative mt-7 max-w-[52ch] text-[15.5px] text-cream-muted">Čím víc lekcí v balíčku využiješ, tím levnější je každá. Jednorázový vstup dává smysl jen na vyzkoušení — pak se vyplatí přejít na měsíční nebo rovnou roční členství.</p>
      </div>
    </section>

    <!-- DOBRÉ VĚDĚT -->
    <section class="mx-auto max-w-[1220px] px-5 pb-10 pt-10 md:px-8">
      <div class="rounded-[20px] border border-border bg-surface p-7 md:p-[clamp(28px,4vw,44px)]">
        <h2 class="mb-[18px] text-[22px] font-extrabold tracking-[-0.02em]">Dobré vědět</h2>
        <ul class="grid gap-x-8 gap-y-3.5 sm:grid-cols-2">
          {priceNotes.map((n) => (
            <li class="flex items-start gap-2.5 text-[15.5px] text-ink-line">
              <span class="mt-[7px] h-1.5 w-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
              <span>{n}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- PROGRAM 8 TÝDNŮ -->
    <section class="mx-auto max-w-[1220px] px-5 pb-10 md:px-8">
      <div class="mb-6 flex flex-wrap items-end justify-between gap-4">
        <h2 class="text-2xl font-extrabold tracking-[-0.02em]">Program 8 týdnů</h2>
        <a href="/program-8-tydnu/" class="cursor-pointer text-base font-bold text-accent-text hover:text-ink">Program — detail →</a>
      </div>
      <a href="/program-8-tydnu/" class="block cursor-pointer rounded-2xl border-2 border-accent bg-surface p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_20px_40px_-20px_rgba(33,31,26,0.24)] sm:flex sm:gap-10">
        <div class="sm:flex-1">
          <span class="mb-3 inline-block rounded-full bg-accent-text px-3 py-1 text-xs font-bold uppercase tracking-[0.04em] text-cream">Vlajkový program</span>
          <h3 class="mb-1 text-[19px] font-extrabold tracking-[-0.02em]">Program 8 týdnů</h3>
          <p class="mb-4 text-[14.5px] text-ink-soft">Uzavřená skupina, vedení trenérem, měření výsledků. Září 2026.</p>
          <ul class="flex flex-col gap-2">
            {['2× pohyb + 1× praktický blok týdně', 'Měření na začátku a na konci', 'Uzavřená skupina do 12 lidí', 'Vedení trenérem celých 8 týdnů'].map((f) => (
              <li class="flex items-start gap-2 text-[14.5px] text-ink-line">
                <span class="mt-[6px] h-1.5 w-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
                <span>{f}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="mt-6 flex flex-col justify-between sm:mt-0 sm:items-end">
          <div>
            <div class="text-[34px] font-extrabold tracking-[-0.02em] text-accent-text">3 900 Kč</div>
            <div class="text-[14px] text-ink-muted">/ celý program</div>
          </div>
          <span class="mt-4 block text-[14px] font-bold text-accent-text sm:mt-0">Detail →</span>
        </div>
      </a>
    </section>

    <!-- FOTOBIOMODULACE -->
    <section class="mx-auto max-w-[1220px] px-5 pb-10 md:px-8">
      <div class="mb-6 flex flex-wrap items-end justify-between gap-4">
        <h2 class="text-2xl font-extrabold tracking-[-0.02em]">Fotobiomodulace</h2>
        <a href="/fotobiomodulacni-terapie/" class="cursor-pointer text-base font-bold text-accent-text hover:text-ink">Fotobiomodulace — detail →</a>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-2xl border border-border bg-surface p-6">
          <div class="mb-1 text-[30px] font-extrabold tracking-[-0.02em] text-accent-text">13 Kč</div>
          <div class="text-[14px] text-ink-muted">/ minuta</div>
        </div>
        <div class="rounded-2xl border-2 border-accent bg-surface p-6">
          <div class="mb-1 text-[30px] font-extrabold tracking-[-0.02em] text-accent-text">180 Kč</div>
          <div class="text-[14px] text-ink-muted">/ 15 minut</div>
          <p class="mt-2 text-[13.5px] font-semibold text-accent-text">Doporučená session</p>
        </div>
        <div class="rounded-2xl border border-border bg-surface p-6">
          <div class="mb-1 text-[30px] font-extrabold tracking-[-0.02em] text-accent-text">783 Kč</div>
          <div class="text-[14px] text-ink-muted">/ 60min pass</div>
          <p class="mt-2 text-[13.5px] text-ink-soft">Balíček minut na více sezení</p>
        </div>
        <div class="rounded-2xl border border-border bg-surface p-6">
          <div class="mb-1 text-[30px] font-extrabold tracking-[-0.02em]">40 Kč</div>
          <div class="text-[14px] text-ink-muted">ochranné brýle</div>
        </div>
      </div>
    </section>

    <!-- KROUŽKY A CIRKUS -->
    <section class="mx-auto max-w-[1220px] px-5 pb-10 md:px-8">
      <div class="mb-6 flex flex-wrap items-end justify-between gap-4">
        <h2 class="text-2xl font-extrabold tracking-[-0.02em]">Kroužky a cirkus</h2>
        <a href="/krouzky-pro-deti/" class="cursor-pointer text-base font-bold text-accent-text hover:text-ink">Kroužky pro děti — detail →</a>
      </div>
      <div class="grid gap-4 sm:grid-cols-3">
        <a href="/krouzky-pro-deti/#cirkusova-skolicka" class="block cursor-pointer rounded-2xl border border-border bg-surface p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_20px_40px_-20px_rgba(33,31,26,0.24)]">
          <h3 class="mb-1 text-[19px] font-extrabold tracking-[-0.02em]">Cirkusová školička</h3>
          <p class="mb-3 text-[14.5px] text-ink-soft">Pro nejmenší, základní pohybové dovednosti</p>
          <div class="text-[30px] font-extrabold tracking-[-0.02em] text-accent-text">4 000 Kč</div>
          <div class="text-[14px] text-ink-muted">/ semestr</div>
          <span class="mt-3 block text-[14px] font-bold text-accent-text">Detail →</span>
        </a>
        <a href="/krouzky-pro-deti/#zaklady-gymnastiky" class="block cursor-pointer rounded-2xl border border-border bg-surface p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_20px_40px_-20px_rgba(33,31,26,0.24)]">
          <h3 class="mb-1 text-[19px] font-extrabold tracking-[-0.02em]">Základy cirkusového tréninku</h3>
          <p class="mb-3 text-[14.5px] text-ink-soft">Gymnastika a akrobacie s La Putyka</p>
          <div class="text-[30px] font-extrabold tracking-[-0.02em] text-accent-text">4 600 Kč</div>
          <div class="text-[14px] text-ink-muted">/ semestr</div>
          <span class="mt-3 block text-[14px] font-bold text-accent-text">Detail →</span>
        </a>
        <a href="/krouzky-pro-deti/#akrobacie-zonglovani" class="block cursor-pointer rounded-2xl border border-border bg-surface p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_20px_40px_-20px_rgba(33,31,26,0.24)]">
          <h3 class="mb-1 text-[19px] font-extrabold tracking-[-0.02em]">Hlavou ve vzduchu</h3>
          <p class="mb-3 text-[14.5px] text-ink-soft">Pozemní i závěsná akrobacie, žonglování</p>
          <div class="text-[30px] font-extrabold tracking-[-0.02em] text-accent-text">5 500 Kč</div>
          <div class="text-[14px] text-ink-muted">/ semestr</div>
          <span class="mt-3 block text-[14px] font-bold text-accent-text">Detail →</span>
        </a>
        <a href="/krouzky-pro-deti/#detska-zumba" class="block cursor-pointer rounded-2xl border border-border bg-surface p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_20px_40px_-20px_rgba(33,31,26,0.24)]">
          <h3 class="mb-1 text-[19px] font-extrabold tracking-[-0.02em]">Dětská Zumba</h3>
          <p class="mb-3 text-[14.5px] text-ink-soft">Tanec a rytmus pro děti 6–12 let</p>
          <div class="text-[30px] font-extrabold tracking-[-0.02em] text-accent-text">3 400 Kč</div>
          <div class="text-[14px] text-ink-muted">/ semestr</div>
          <span class="mt-3 block text-[14px] font-bold text-accent-text">Detail →</span>
        </a>
        <a href="/krouzky-pro-deti/#objevovarna" class="block cursor-pointer rounded-2xl border border-border bg-surface p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_20px_40px_-20px_rgba(33,31,26,0.24)]">
          <h3 class="mb-1 text-[19px] font-extrabold tracking-[-0.02em]">Objevovárna</h3>
          <p class="mb-3 text-[14.5px] text-ink-soft">Nevedená hernička pro děti do 5 let</p>
          <div class="text-[30px] font-extrabold tracking-[-0.02em] text-accent-text">250 Kč</div>
          <div class="text-[14px] text-ink-muted">/ vstup</div>
          <span class="mt-3 block text-[14px] font-bold text-accent-text">Detail →</span>
        </a>
      </div>
    </section>

    <!-- PRONÁJEM SÁLŮ -->
    <section class="mx-auto max-w-[1220px] px-5 pb-16 pt-0 md:px-8 md:pb-23">
      <div class="mb-6 flex flex-wrap items-baseline justify-between gap-4">
        <h2 class="text-2xl font-extrabold tracking-[-0.02em]">Pronájem sálů</h2>
        <a href="/pronajem-salu/" class="cursor-pointer text-base font-bold text-accent-text hover:text-ink">Detail pronájmu →</a>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-2xl border border-border bg-surface p-6">
          <h3 class="mb-1 text-[17px] font-extrabold">Velký sál</h3>
          <div class="text-[30px] font-extrabold tracking-[-0.02em] text-accent-text">700 Kč</div>
          <div class="text-[14px] text-ink-muted">/ hod</div>
        </div>
        <div class="rounded-2xl border border-border bg-surface p-6">
          <h3 class="mb-1 text-[17px] font-extrabold">Střední sál</h3>
          <div class="text-[30px] font-extrabold tracking-[-0.02em] text-accent-text">600 Kč</div>
          <div class="text-[14px] text-ink-muted">/ hod</div>
        </div>
        <div class="rounded-2xl border border-border bg-surface p-6">
          <h3 class="mb-1 text-[17px] font-extrabold">Malý sál</h3>
          <div class="text-[30px] font-extrabold tracking-[-0.02em] text-accent-text">500 Kč</div>
          <div class="text-[14px] text-ink-muted">/ hod</div>
        </div>
        <div class="rounded-2xl border border-border bg-surface p-6">
          <h3 class="mb-1 text-[17px] font-extrabold">Fitness sál</h3>
          <div class="text-[30px] font-extrabold tracking-[-0.02em] text-accent-text">350 Kč</div>
          <div class="text-[14px] text-ink-muted">/ hod</div>
        </div>
      </div>
      <p class="mt-4 text-[14.5px] text-ink-soft">Hodinový pronájem při smlouvě min. na 6 měsíců. Poptávka: <a href="/kontakt/" class="font-bold text-accent-text hover:text-ink">napsat nám →</a></p>
    </section>
  </main>
  <Footer />
</Layout>
