---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Button from '../../components/Button.astro';
import { pricing } from '../../data/home.en';

const priceNotes = [
  'Multisport, Benefit Plus, Edenred and Sodexo accepted (some classes excluded).',
  'We are happy to issue an invoice for your employer or FKSP benefit fund.',
  'Membership applies to circuit, strength, Supermums, HIIT and bodyweight classes.',
  'Hall rental is hourly with a minimum 6-month contract.',
];
---
<Layout
  title="Pricing — BoHeMi fitness Vinohrady"
  description="BoHeMi pricing: single entry, membership and the 8-Week Program. Membership pays off from the third class per week. We accept Multisport and benefit cards."
  lang="en"
  current="/en/pricing/"
>
  <Header current="/en/pricing/" lang="en" />
  <main>
    <!-- HERO -->
    <section class="mx-auto max-w-[1220px] px-5 pb-12 pt-16 md:px-8 md:pt-20">
      <h1 class="text-[clamp(40px,6.2vw,76px)] font-extrabold leading-[0.98] tracking-[-0.035em]">
        What it <span class="font-medium italic text-accent-text">costs</span>
      </h1>
      <p class="mt-6 max-w-[54ch] text-[clamp(18px,2.1vw,22px)] leading-[1.45] text-ink-warm">
        Membership, single entries and the full programme. Choose based on how deep you want to go.
      </p>
    </section>

    <!-- PRICING CARDS -->
    <section class="mx-auto max-w-[1220px] px-5 pb-6 md:px-8">
      <div class="grid gap-[22px] md:grid-cols-3">
        {pricing.map((pl) => (
          <div class={`relative flex flex-col rounded-[20px] border bg-surface px-8 py-9 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_22px_44px_-20px_rgba(33,31,26,0.24)] ${pl.featured ? 'border-2 border-accent' : 'border-border'}`}>
            {pl.badge && (
              <span class="absolute -top-2.5 left-8 rounded-full bg-accent-text px-3.5 py-1.5 text-xs font-bold uppercase tracking-[0.04em] text-cream">{pl.badge}</span>
            )}
            <h2 class="mb-1 text-2xl font-extrabold tracking-[-0.02em]">{pl.t}</h2>
            <p class="mb-[18px] text-[15px] text-ink-muted">{pl.d}</p>
            <div class="mb-1.5 flex items-baseline gap-1.5">
              <span class="text-[38px] font-extrabold tracking-[-0.02em]">{pl.price}</span>
              <span class="text-[15px] text-ink-muted">{pl.per}</span>
            </div>
            <p class="mb-[18px] min-h-[18px] text-[13.5px] font-semibold text-accent-text">{pl.note}</p>
            <ul class="mb-7 flex flex-col gap-3">
              {pl.feat.map((f) => (
                <li class="flex items-start gap-2.5 text-[15.5px] text-ink-line">
                  <span class="mt-[7px] h-1.5 w-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
                  <span>{f}</span>
                </li>
              ))}
            </ul>
            <Button href="/en/contact/" variant="dark" class="mt-auto px-[22px] py-3 text-[15.5px]">Choose this</Button>
          </div>
        ))}
      </div>
    </section>

    <!-- DOING THE MATHS? -->
    <section class="mx-auto max-w-[1220px] px-5 pb-2 pt-10 md:px-8">
      <div class="relative overflow-hidden rounded-[20px] bg-ink-dark p-8 text-cream md:p-[clamp(32px,5vw,52px)]">
        <div
          class="pointer-events-none absolute -right-16 -top-20 h-[360px] w-[360px] rounded-full"
          style="background:radial-gradient(circle, rgba(226,35,26,0.16), rgba(226,35,26,0) 70%);"
          aria-hidden="true"
        >
        </div>
        <p class="relative mb-2 italic text-[23px] text-sage">Doing the maths?</p>
        <h2 class="relative mb-9 max-w-[22ch] text-[clamp(26px,3.4vw,40px)] font-extrabold tracking-[-0.03em]">Membership works out at ~187 CZK per class.</h2>

        <div class="relative flex max-w-[760px] flex-col gap-[26px]">
          <div>
            <div class="mb-2.5 flex items-baseline justify-between">
              <span class="text-base font-semibold text-cream-soft">Single entry</span>
              <span class="text-xl font-extrabold">250 CZK <span class="text-sm font-medium text-cream-muted">/ class</span></span>
            </div>
            <div class="h-3.5 overflow-hidden rounded-full bg-border-dark">
              <div class="h-full w-full rounded-full bg-accent"></div>
            </div>
          </div>
          <div>
            <div class="mb-2.5 flex items-baseline justify-between">
              <span class="text-base font-semibold text-cream">Membership (8 classes)</span>
              <span class="text-xl font-extrabold text-sage">~187 CZK <span class="text-sm font-medium text-cream-muted">/ class</span></span>
            </div>
            <div class="h-3.5 overflow-hidden rounded-full bg-border-dark">
              <div class="h-full w-[75%] rounded-full bg-sage"></div>
            </div>
          </div>
        </div>

        <p class="relative mt-7 max-w-[52ch] text-[15.5px] text-cream-muted">The more classes in the pack you use, the cheaper each one gets. A single entry makes sense only for a trial — after that membership or the 8-Week Program is the better value.</p>
      </div>
    </section>

    <!-- GOOD TO KNOW -->
    <section class="mx-auto max-w-[1220px] px-5 pb-10 pt-10 md:px-8">
      <div class="rounded-[20px] border border-border bg-surface p-7 md:p-[clamp(28px,4vw,44px)]">
        <h2 class="mb-[18px] text-[22px] font-extrabold tracking-[-0.02em]">Good to know</h2>
        <ul class="grid gap-x-8 gap-y-3.5 sm:grid-cols-2">
          {priceNotes.map((n) => (
            <li class="flex items-start gap-2.5 text-[15.5px] text-ink-line">
              <span class="mt-[7px] h-1.5 w-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
              <span>{n}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- PHOTOBIOMODULATION -->
    <section class="mx-auto max-w-[1220px] px-5 pb-10 md:px-8">
      <div class="mb-6 flex flex-wrap items-end justify-between gap-4">
        <h2 class="text-2xl font-extrabold tracking-[-0.02em]">Photobiomodulation</h2>
        <a href="/en/photobiomodulation-therapy/" class="cursor-pointer text-base font-bold text-accent-text hover:text-ink">Photobiomodulation — details →</a>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-2xl border border-border bg-surface p-6">
          <div class="mb-1 text-[30px] font-extrabold tracking-[-0.02em] text-accent-text">13 CZK</div>
          <div class="text-[14px] text-ink-muted">/ minute</div>
        </div>
        <div class="rounded-2xl border-2 border-accent bg-surface p-6">
          <div class="mb-1 text-[30px] font-extrabold tracking-[-0.02em] text-accent-text">180 CZK</div>
          <div class="text-[14px] text-ink-muted">/ 15 minutes</div>
          <p class="mt-2 text-[13.5px] font-semibold text-accent-text">Recommended session</p>
        </div>
        <div class="rounded-2xl border border-border bg-surface p-6">
          <div class="mb-1 text-[30px] font-extrabold tracking-[-0.02em] text-accent-text">783 CZK</div>
          <div class="text-[14px] text-ink-muted">/ 60-min pass</div>
          <p class="mt-2 text-[13.5px] text-ink-soft">Bundle of minutes for multiple sessions</p>
        </div>
        <div class="rounded-2xl border border-border bg-surface p-6">
          <div class="mb-1 text-[30px] font-extrabold tracking-[-0.02em]">40 CZK</div>
          <div class="text-[14px] text-ink-muted">protective glasses</div>
        </div>
      </div>
    </section>

    <!-- CLUBS & CIRCUS -->
    <section class="mx-auto max-w-[1220px] px-5 pb-10 md:px-8">
      <div class="mb-6 flex flex-wrap items-end justify-between gap-4">
        <h2 class="text-2xl font-extrabold tracking-[-0.02em]">Clubs & circus</h2>
        <a href="/krouzky-pro-deti/" class="cursor-pointer text-base font-bold text-accent-text hover:text-ink">Kids clubs — details →</a>
      </div>
      <div class="grid gap-4 sm:grid-cols-3">
        <a href="/krouzky-pro-deti/#cirkusova-skolicka" class="block cursor-pointer rounded-2xl border border-border bg-surface p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_20px_40px_-20px_rgba(33,31,26,0.24)]">
          <h3 class="mb-1 text-[19px] font-extrabold tracking-[-0.02em]">Circus School</h3>
          <p class="mb-3 text-[14.5px] text-ink-soft">For the youngest — basic movement skills</p>
          <div class="text-[30px] font-extrabold tracking-[-0.02em] text-accent-text">4 000 CZK</div>
          <div class="text-[14px] text-ink-muted">/ semester</div>
          <span class="mt-3 block text-[14px] font-bold text-accent-text">Details →</span>
        </a>
        <a href="/krouzky-pro-deti/#zaklady-gymnastiky" class="block cursor-pointer rounded-2xl border border-border bg-surface p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_20px_40px_-20px_rgba(33,31,26,0.24)]">
          <h3 class="mb-1 text-[19px] font-extrabold tracking-[-0.02em]">Circus training basics</h3>
          <p class="mb-3 text-[14.5px] text-ink-soft">Gymnastics and acrobatics with La Putyka</p>
          <div class="text-[30px] font-extrabold tracking-[-0.02em] text-accent-text">4 600 CZK</div>
          <div class="text-[14px] text-ink-muted">/ semester</div>
          <span class="mt-3 block text-[14px] font-bold text-accent-text">Details →</span>
        </a>
        <a href="/krouzky-pro-deti/#akrobacie-zonglovani" class="block cursor-pointer rounded-2xl border border-border bg-surface p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_20px_40px_-20px_rgba(33,31,26,0.24)]">
          <h3 class="mb-1 text-[19px] font-extrabold tracking-[-0.02em]">Hlavou ve vzduchu</h3>
          <p class="mb-3 text-[14.5px] text-ink-soft">Floor & aerial acrobatics, juggling</p>
          <div class="text-[30px] font-extrabold tracking-[-0.02em] text-accent-text">5 500 CZK</div>
          <div class="text-[14px] text-ink-muted">/ semester</div>
          <span class="mt-3 block text-[14px] font-bold text-accent-text">Details →</span>
        </a>
        <a href="/krouzky-pro-deti/#detska-zumba" class="block cursor-pointer rounded-2xl border border-border bg-surface p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_20px_40px_-20px_rgba(33,31,26,0.24)]">
          <h3 class="mb-1 text-[19px] font-extrabold tracking-[-0.02em]">Kids Zumba</h3>
          <p class="mb-3 text-[14.5px] text-ink-soft">Dance & rhythm for kids aged 6–12</p>
          <div class="text-[30px] font-extrabold tracking-[-0.02em] text-accent-text">3 400 CZK</div>
          <div class="text-[14px] text-ink-muted">/ semester</div>
          <span class="mt-3 block text-[14px] font-bold text-accent-text">Details →</span>
        </a>
        <a href="/krouzky-pro-deti/#objevovarna" class="block cursor-pointer rounded-2xl border border-border bg-surface p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_20px_40px_-20px_rgba(33,31,26,0.24)]">
          <h3 class="mb-1 text-[19px] font-extrabold tracking-[-0.02em]">Discovery Room</h3>
          <p class="mb-3 text-[14.5px] text-ink-soft">Unguided play space for kids under 5</p>
          <div class="text-[30px] font-extrabold tracking-[-0.02em] text-accent-text">250 CZK</div>
          <div class="text-[14px] text-ink-muted">/ visit</div>
          <span class="mt-3 block text-[14px] font-bold text-accent-text">Details →</span>
        </a>
      </div>
    </section>

    <!-- HALL RENTAL -->
    <section class="mx-auto max-w-[1220px] px-5 pb-16 pt-0 md:px-8 md:pb-23">
      <h2 class="mb-6 text-2xl font-extrabold tracking-[-0.02em]">Hall rental</h2>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-2xl border border-border bg-surface p-6">
          <h3 class="mb-1 text-[17px] font-extrabold">Large hall</h3>
          <div class="text-[30px] font-extrabold tracking-[-0.02em] text-accent-text">700 CZK</div>
          <div class="text-[14px] text-ink-muted">/ hr</div>
        </div>
        <div class="rounded-2xl border border-border bg-surface p-6">
          <h3 class="mb-1 text-[17px] font-extrabold">Medium hall</h3>
          <div class="text-[30px] font-extrabold tracking-[-0.02em] text-accent-text">600 CZK</div>
          <div class="text-[14px] text-ink-muted">/ hr</div>
        </div>
        <div class="rounded-2xl border border-border bg-surface p-6">
          <h3 class="mb-1 text-[17px] font-extrabold">Small hall</h3>
          <div class="text-[30px] font-extrabold tracking-[-0.02em] text-accent-text">500 CZK</div>
          <div class="text-[14px] text-ink-muted">/ hr</div>
        </div>
        <div class="rounded-2xl border border-border bg-surface p-6">
          <h3 class="mb-1 text-[17px] font-extrabold">Fitness studio</h3>
          <div class="text-[30px] font-extrabold tracking-[-0.02em] text-accent-text">350 CZK</div>
          <div class="text-[14px] text-ink-muted">/ hr</div>
        </div>
      </div>
      <p class="mt-4 text-[14.5px] text-ink-soft">Hourly rental with a minimum 6-month contract. Enquiries: <a href="/en/contact/" class="font-bold text-accent-text hover:text-ink">write to us →</a></p>
    </section>
  </main>
  <Footer lang="en" />
</Layout>
