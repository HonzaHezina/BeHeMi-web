---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Eyebrow from '../../components/Eyebrow.astro';
import Button from '../../components/Button.astro';
import HealthTracker from '../../components/HealthTracker.astro';

const teacher = [
  { k: 'Circuit training', d: 'Teaches you to follow through. Station after station, no excuses.' },
  { k: 'Juggling', d: 'Teaches focus, rhythm and patience — and the ability to read patterns better.' },
  { k: 'Breath', d: 'Teaches you to calm down and bring attention back to the body.' },
  { k: 'Strength', d: 'Teaches patience and the fact that progress is slow but honest.' },
];
---
<Layout
  title="Why BoHeMi — the body as a school for life"
  description="The BoHeMi story: movement that goes beyond muscles. How training opens a path to the mind, habits, breath and balance — and why we do it as a community in Vinohrady."
  lang="en"
  current="/en/why-bohemi/"
>
  <Header current="/en/why-bohemi/" lang="en" />
  <main>
    <!-- HERO -->
    <section class="relative mx-auto max-w-[1100px] overflow-hidden px-5 pb-12 pt-16 md:px-8 md:pt-20">
      <div
        class="pointer-events-none absolute right-0 top-0 h-[420px] w-[420px] rounded-full"
        style="background:radial-gradient(circle, rgba(226,35,26,0.12), rgba(226,35,26,0) 70%);"
        aria-hidden="true"
      >
      </div>
      <div class="relative">
        <Eyebrow>Why BoHeMi</Eyebrow>
        <h1 class="max-w-[15ch] text-[clamp(40px,6.2vw,76px)] font-extrabold leading-[0.98] tracking-[-0.035em]">
          The body as a <span class="font-medium italic text-accent-text">school for life.</span>
        </h1>
        <p class="mt-5 text-[clamp(19px,2.2vw,24px)] font-semibold text-ink-soft">Movement that goes beyond muscles.</p>
      </div>
    </section>

    <!-- STORY -->
    <section class="mx-auto max-w-[860px] px-5 pb-6 md:px-8">
      <div class="flex flex-col gap-5 text-[19px] leading-[1.6] text-ink-line">
        <p>BoHeMi grew out of a personal experience — that movement is not just physical activity. When I started exercising regularly, it wasn't just my body that changed; gradually I became better at focusing, finishing things, and handling stress.</p>
        <p>Circuit training taught me to follow through. Juggling taught patience, rhythm, attention, and the ability to read patterns. I slowly realised that through the body you can also open a path to the mind, habits, and balance.</p>
        <p>The body is the simplest place to start — because you feel it immediately and you can see the result.</p>
      </div>
      <figure class="mt-9 border-y border-border-strong py-8">
        <blockquote class="text-[clamp(24px,3vw,34px)] italic leading-[1.3] tracking-[-0.015em] text-ink">"Through the body I started learning things that later helped me in work and in life."</blockquote>
        <figcaption class="mt-4 text-[15px] text-ink-muted">— Jan Hezina, founder of BoHeMi</figcaption>
      </figure>
    </section>

    <!-- BODY AS TEACHER -->
    <section class="mx-auto max-w-[1100px] px-5 py-14 md:px-8 md:py-15">
      <h2 class="mb-9 text-[clamp(28px,3.6vw,44px)] font-extrabold tracking-[-0.03em]">The body as a <span class="font-medium italic text-accent-text">teacher.</span></h2>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {teacher.map((item) => (
          <div class="rounded-[18px] border border-border bg-surface px-[26px] py-[30px]">
            <h3 class="mb-2 text-[22px] font-extrabold tracking-[-0.02em] text-brand">{item.k}</h3>
            <p class="text-base leading-[1.5] text-ink-soft">{item.d}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- TRANSITION -->
    <section class="mx-auto max-w-[860px] px-5 pb-6 pt-6 md:px-8">
      <p class="text-lg leading-[1.6] text-ink-soft">We take nothing as dogma; what we suggest, you try on your own skin. Just regular movement, recovery, and a group of people who show up to the same class as you — practice that works or doesn't, and you'll know soon enough.</p>
    </section>

    <HealthTracker lang="en" />

    <!-- CTA -->
    <section class="mx-auto max-w-[1100px] px-5 pb-20 pt-8 text-center md:px-8">
      <h2 class="mx-auto mb-5 max-w-[20ch] text-[clamp(28px,4vw,46px)] font-extrabold tracking-[-0.035em]">Start with the body. Continue with practice.</h2>
      <p class="mx-auto mb-7 max-w-[44ch] text-lg text-ink-soft">The simplest first step is to come to a class or join the next 8-Week Program group.</p>
      <div class="flex flex-wrap justify-center gap-3.5">
        <Button href="/program-8-tydnu/" variant="brand">8-Week Program →</Button>
        <Button href="/en/group-classes/" variant="outline">Class schedule</Button>
      </div>
    </section>
  </main>
  <Footer lang="en" />
</Layout>
