---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import MediaFrame from '../../components/MediaFrame.astro';
import { classes } from '../../data/home.en';
---
<Layout
  title="Group classes — BoHeMi fitness Vinohrady"
  description="All group classes at BoHeMi fitness in Prague's Vinohrady. Circuit training, HIIT, strength, bodyweight, Zumba and more — coach-led in a small group."
  lang="en"
  current="/en/group-classes/"
>
  <Header current="/en/group-classes/" lang="en" />
  <main>
    <section class="relative mx-auto max-w-[1220px] overflow-hidden px-5 pb-8 pt-16 md:px-8 md:pt-20">
      <div
        class="pointer-events-none absolute right-0 top-2.5 h-[400px] w-[400px] rounded-full"
        style="background:radial-gradient(circle, rgba(226,35,26,0.12), rgba(226,35,26,0) 70%);"
        aria-hidden="true"
      ></div>
      <div class="relative">
        <p class="mb-4 text-[13px] font-extrabold uppercase tracking-[0.08em] text-accent-text">
          <a href="/en/classes-and-services/" class="hover:text-ink">Classes &amp; services</a> · Group classes
        </p>
        <h1 class="text-[clamp(40px,6.2vw,76px)] font-extrabold leading-[0.98] tracking-[-0.035em]">
          Group <span class="font-medium text-accent-text">classes</span>
        </h1>
        <p class="mt-6 max-w-[56ch] text-[clamp(18px,2.1vw,22px)] leading-[1.45] text-ink-warm">
          Ten classes, each with a different focus — the coach leads, you train. Find what suits you.
        </p>
      </div>
    </section>

    <section class="mx-auto max-w-[1220px] px-5 pb-12 pt-6 md:px-8 md:pb-16">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {classes.map((c) => (
          <div id={c.id} class:list={[
            'relative scroll-mt-24 overflow-hidden rounded-2xl border border-border bg-surface',
            c.page && 'transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_20px_40px_-20px_rgba(33,31,26,0.24)]',
          ]}>
            <MediaFrame media={c.media} rounded="rounded-none" class="h-44" alt={`Class — ${c.img}`} />
            <div class="p-[22px]">
              <h2 class="mb-2 text-[21px] font-extrabold tracking-[-0.02em]">{c.t}</h2>
              <p class="text-[15.5px] leading-[1.5] text-ink-soft">{c.d}</p>
              <div class="mt-3 text-[12.5px] font-bold tracking-[0.02em] text-brand">{c.bhm}</div>
              <div class="mt-4 flex flex-wrap gap-5">
                {c.page && <a href={c.page} class="absolute inset-0" aria-label={`${c.t} — details`}></a>}
                <a href="https://bohemi.fit/rezervace/" class="relative text-[14px] font-bold text-accent-text hover:text-ink">Book →</a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="mx-auto max-w-[1220px] px-5 pb-16 md:px-8 md:pb-23">
      <div class="relative flex flex-wrap items-center justify-between gap-6 overflow-hidden rounded-[22px] bg-ink-dark p-8 text-cream md:p-[clamp(32px,5vw,56px)]">
        <div
          class="pointer-events-none absolute -bottom-22 -right-12 h-[340px] w-[340px] rounded-full"
          style="background:radial-gradient(circle, rgba(226,35,26,0.18), rgba(226,35,26,0) 70%);"
          aria-hidden="true"
        ></div>
        <div class="relative">
          <h2 class="max-w-[20ch] text-[clamp(26px,3.4vw,40px)] font-extrabold tracking-[-0.03em]">Not sure which class is right for you?</h2>
          <p class="mt-3 max-w-[42ch] text-[17px] text-cream-muted">Write to us — we'll recommend what fits your level and goal.</p>
        </div>
        <a
          href="/en/contact/"
          class="relative inline-flex shrink-0 cursor-pointer items-center gap-2 rounded-full bg-accent-text px-7 py-3.5 text-[17px] font-bold text-cream transition-colors hover:bg-accent-deep"
        >
          Get in touch →
        </a>
      </div>
    </section>
  </main>
  <Footer lang="en" />
</Layout>
