  lang="en"
  current="/en/"
>
  <Header current="/en/" lang="en" />
  <main>
    <Hero lang="en" />
    <ApproachGrid lang="en" />
    <KidsBand lang="en" />
    <Offer lang="en" />
    <LifePracticeFeature lang="en" />
    <ProcTriad lang="en" />
    <Trainers lang="en" />
    <PricingTeaser lang="en" />
  </main>
  <Footer lang="en" />
</Layout>
