---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Hero from "../../components/Hero.astro";
import Marquee from "../../components/Marquee.astro";
import ApproachGrid from "../../components/ApproachGrid.astro";
import Offer from "../../components/Offer.astro";
import LifePracticeFeature from "../../components/LifePracticeFeature.astro";
import ProcTeaser from "../../components/ProcTeaser.astro";
import TriadVenn from "../../components/TriadVenn.astro";
import Audiences from "../../components/Audiences.astro";
import Trainers from "../../components/Trainers.astro";
import PricingTeaser from "../../components/PricingTeaser.astro";
---
<Layout
  title="BoHeMi — small group training in Vinohrady, Prague"
  description="BoHeMi is a small fitness studio in Prague's Vinohrady district. Group training where the coach truly knows you — body toning, fitness, proper routine. Start with one class."
  lang="en"
  current="/en/"
>
  <Header current="/en/" lang="en" />
  <main>
    <Hero lang="en" />
    <Marquee lang="en" />
    <ApproachGrid lang="en" />
    <section class="mx-auto max-w-[1220px] px-5 py-16 md:px-8 md:py-20">
      <h2 class="mb-5 text-[clamp(26px,3.2vw,38px)] font-extrabold leading-[1.06] tracking-[-0.03em]">How we train here</h2>
      <p class="mb-8 max-w-[60ch] text-[18px] leading-[1.55] text-ink-warm">BoHeMi is a fitness studio in Prague's Vinohrady neighbourhood focused on coached classes, circuit training, and functional movement. No big machines, no complicated programs — just movement that works.</p>
      <ul class="flex flex-col gap-4">
        <li class="flex items-start gap-3.5 text-[17px] leading-[1.5] text-ink-line">
          <span class="mt-0.5 flex h-[22px] w-[22px] shrink-0 items-center justify-center rounded-full bg-accent/12 text-[13px] font-extrabold text-accent-text" aria-hidden="true">✓</span>
          <span><strong class="font-bold text-ink">Small groups of up to 12 people</strong> — the coach knows you and corrects your form</span>
        </li>
        <li class="flex items-start gap-3.5 text-[17px] leading-[1.5] text-ink-line">
          <span class="mt-0.5 flex h-[22px] w-[22px] shrink-0 items-center justify-center rounded-full bg-accent/12 text-[13px] font-extrabold text-accent-text" aria-hidden="true">✓</span>
          <span>Train with bodyweight, TRX, kettlebells and other equipment — no machines</span>
        </li>
        <li class="flex items-start gap-3.5 text-[17px] leading-[1.5] text-ink-line">
          <span class="mt-0.5 flex h-[22px] w-[22px] shrink-0 items-center justify-center rounded-full bg-accent/12 text-[13px] font-extrabold text-accent-text" aria-hidden="true">✓</span>
          <span>Every class has a clear structure: warm-up, main workout, cool-down</span>
        </li>
        <li class="flex items-start gap-3.5 text-[17px] leading-[1.5] text-ink-line">
          <span class="mt-0.5 flex h-[22px] w-[22px] shrink-0 items-center justify-center rounded-full bg-accent/12 text-[13px] font-extrabold text-accent-text" aria-hidden="true">✓</span>
          <span>Difficulty adapts to your level — no need to worry about starting out</span>
        </li>
        <li class="flex items-start gap-3.5 text-[17px] leading-[1.5] text-ink-line">
          <span class="mt-0.5 flex h-[22px] w-[22px] shrink-0 items-center justify-center rounded-full bg-accent/12 text-[13px] font-extrabold text-accent-text" aria-hidden="true">✓</span>
          <span>Progressive approach: we gradually increase intensity, not all at once</span>
        </li>
      </ul>
    </section>
    <Offer lang="en" />
    <LifePracticeFeature lang="en" />
    <ProcTeaser lang="en" />
    <TriadVenn lang="en" />
    <Audiences lang="en" />
    <Trainers lang="en" />
    <PricingTeaser lang="en" />
  </main>
  <Footer lang="en" />
</Layout>
