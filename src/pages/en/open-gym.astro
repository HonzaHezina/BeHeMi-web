---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Button from '../../components/Button.astro';

const highlights = [
  { stat: '100 m²', d: 'The whole studio just for you. No strangers, no noise, no waiting.' },
  { stat: 'Max 5', d: 'Maximum 5 people per booking — ideal for a small group or a bunch of friends.' },
  { stat: '60 min', d: 'One-hour blocks — enough time for warm-up, workout and cool-down without stress.' },
];

const equipment = [
  'Kettlebells (various weights)',
  'TRX suspension trainer',
  'Resistance bands',
  'Floor mats',
  'Functional training accessories',
];
---
<Layout
  title="Open Gym — BoHeMi fitness Vinohrady"
  description="Private 100 m² studio just for you or a small group. Kettlebells, TRX, resistance bands — Open Gym at BoHeMi in Prague's Vinohrady."
  lang="en"
  current="/en/open-gym/"
>
  <Header current="/en/open-gym/" lang="en" />
  <main>
    <section class="relative mx-auto max-w-[1220px] overflow-hidden px-5 pb-10 pt-16 md:px-8 md:pt-20">
      <div
        class="pointer-events-none absolute right-0 top-2.5 h-[400px] w-[400px] rounded-full"
        style="background:radial-gradient(circle, rgba(226,35,26,0.12), rgba(226,35,26,0) 70%);"
        aria-hidden="true"
      ></div>
      <div class="relative">
        <p class="mb-4 text-[13px] font-extrabold uppercase tracking-[0.08em] text-accent-text">
          <a href="/en/classes-and-services/" class="hover:text-ink">Classes &amp; services</a> · Individual services
        </p>
        <h1 class="text-[clamp(40px,6.2vw,76px)] font-extrabold leading-[0.98] tracking-[-0.035em]">
          Open <span class="font-medium text-accent-text">Gym</span>
        </h1>
        <p class="mt-6 max-w-[56ch] text-[clamp(18px,2.1vw,22px)] leading-[1.45] text-ink-warm">
          Private 100 m² studio just for you or a small group. Train alone or with friends — no crowds, no waiting.
        </p>
        <div class="mt-8 flex flex-wrap gap-3.5">
          <Button href="https://studio.bohemi.fit/" variant="primary">Book Open Gym →</Button>
          <Button href="/en/contact/" variant="outline">Ask us for details</Button>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-[1220px] px-5 py-8 md:px-8">
      <div class="grid gap-5 sm:grid-cols-3">
        {highlights.map((h) => (
          <div class="rounded-2xl border border-border bg-surface p-7">
            <div class="mb-2 text-[34px] font-extrabold text-accent-text">{h.stat}</div>
            <p class="text-[15.5px] text-ink-soft">{h.d}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="mx-auto max-w-[1220px] px-5 py-6 md:px-8">
      <h2 class="mb-6 text-2xl font-extrabold tracking-[-0.02em]">Equipment</h2>
      <ul class="grid gap-3 sm:grid-cols-2 md:grid-cols-3">
        {equipment.map((e) => (
          <li class="flex items-start gap-3 text-[16px] text-ink-soft">
            <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
            {e}
          </li>
        ))}
      </ul>
    </section>

    <section class="mx-auto max-w-[1220px] px-5 py-6 md:px-8">
      <h2 class="mb-6 text-2xl font-extrabold tracking-[-0.02em]">Available slots</h2>
      <p class="mb-6 max-w-[52ch] text-[16px] text-ink-soft">
        Open Gym is available Monday through Thursday. Check current availability and book online.
      </p>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-2xl border border-border bg-surface p-5">
          <div class="mb-3 text-[13px] font-extrabold uppercase tracking-[0.06em] text-accent-text">Monday</div>
          <ul class="flex flex-col gap-1.5 text-[15px] text-ink-soft">
            <li>15:00 – 16:00</li>
            <li>18:30 – 19:30</li>
          </ul>
        </div>
        <div class="rounded-2xl border border-border bg-surface p-5">
          <div class="mb-3 text-[13px] font-extrabold uppercase tracking-[0.06em] text-accent-text">Tuesday</div>
          <ul class="flex flex-col gap-1.5 text-[15px] text-ink-soft">
            <li>14:00 – 16:00</li>
            <li>19:30 – 21:30</li>
          </ul>
        </div>
        <div class="rounded-2xl border border-border bg-surface p-5">
          <div class="mb-3 text-[13px] font-extrabold uppercase tracking-[0.06em] text-accent-text">Wednesday</div>
          <ul class="flex flex-col gap-1.5 text-[15px] text-ink-soft">
            <li>19:00 – 21:00</li>
          </ul>
        </div>
        <div class="rounded-2xl border border-border bg-surface p-5">
          <div class="mb-3 text-[13px] font-extrabold uppercase tracking-[0.06em] text-accent-text">Thursday</div>
          <ul class="flex flex-col gap-1.5 text-[15px] text-ink-soft">
            <li>14:00 – 16:00</li>
            <li>19:30 – 21:30</li>
          </ul>
        </div>
      </div>
      <div class="mt-6">
        <Button href="https://studio.bohemi.fit/" variant="brand">View all slots →</Button>
      </div>
    </section>

    <section class="mx-auto max-w-[1220px] px-5 pb-16 pt-10 md:px-8 md:pb-23">
      <div class="relative flex flex-wrap items-center justify-between gap-6 overflow-hidden rounded-[22px] bg-ink-dark p-8 text-cream md:p-[clamp(32px,5vw,56px)]">
        <div
          class="pointer-events-none absolute -bottom-22 -right-12 h-[340px] w-[340px] rounded-full"
          style="background:radial-gradient(circle, rgba(226,35,26,0.18), rgba(226,35,26,0) 70%);"
          aria-hidden="true"
        ></div>
        <div class="relative">
          <h2 class="max-w-[22ch] text-[clamp(26px,3.4vw,40px)] font-extrabold tracking-[-0.03em]">Want the studio to yourself?</h2>
          <p class="mt-3 max-w-[42ch] text-[17px] text-cream-muted">Book a slot directly or write to us — we'll help you find the right time and workout plan.</p>
        </div>
        <a
          href="https://studio.bohemi.fit/"
          class="relative inline-flex shrink-0 cursor-pointer items-center gap-2 rounded-full bg-accent-text px-7 py-3.5 text-[17px] font-bold text-cream transition-colors hover:bg-accent-deep"
        >
          Book Open Gym →
        </a>
      </div>
    </section>
  </main>
  <Footer lang="en" />
</Layout>
