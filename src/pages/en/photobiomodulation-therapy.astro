---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Button from '../../components/Button.astro';

const benefits = [
  { t: 'Faster recovery', d: 'Muscles recover faster after training and after demanding days.' },
  { t: 'Better sleep', d: 'Regular use affects your circadian rhythm — falling asleep and sleep depth both improve.' },
  { t: 'Less inflammation', d: 'The NIR component penetrates deep into tissue and reduces the chronic inflammation that often sits behind pain and fatigue.' },
  { t: 'Collagen support', d: 'Red light supports collagen production — helps joints, tendons, and skin recover.' },
  { t: 'Athletic performance', d: 'Better circulation and oxygenation in muscles shows up in performance and in how fast you recover.' },
  { t: 'Simple protocol', d: '15 minutes, 3–5× per week. Lie under the panel and relax.' },
];
---
<Layout
  title="Photobiomodulation — BoHeMi fitness Vinohrady"
  description="LED RED and NIR light therapy for recovery, better sleep and athletic performance. Photobiomodulation at BoHeMi in Prague's Vinohrady — 15 minutes, big effect."
  lang="en"
  current="/en/photobiomodulation-therapy/"
>
  <Header current="/en/photobiomodulation-therapy/" lang="en" />
  <main>
    <section class="relative mx-auto max-w-[1220px] overflow-hidden px-5 pb-10 pt-16 md:px-8 md:pt-20">
      <div
        class="pointer-events-none absolute right-0 top-2.5 h-[400px] w-[400px] rounded-full"
        style="background:radial-gradient(circle, rgba(226,35,26,0.12), rgba(226,35,26,0) 70%);"
        aria-hidden="true"
      ></div>
      <div class="relative max-w-[720px]">
        <p class="mb-4 text-[13px] font-extrabold uppercase tracking-[0.08em] text-accent-text">
          <a href="/en/classes-and-services/" class="hover:text-ink">Classes &amp; services</a> · Individual services
        </p>
        <h1 class="text-[clamp(40px,6.2vw,76px)] font-extrabold leading-[0.98] tracking-[-0.035em]">
          Photo&shy;bio&shy;modulation
        </h1>
        <p class="mt-6 max-w-[56ch] text-[clamp(18px,2.1vw,22px)] leading-[1.45] text-ink-warm">
          Light therapy using red (RED) and near-infrared (NIR) wavelengths for faster recovery, better sleep and athletic performance.
        </p>
        <div class="mt-8">
          <Button href="https://bohemi.fit/rezervace/" variant="primary">Book →</Button>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-[1220px] px-5 py-10 md:px-8">
      <div class="rounded-[22px] border border-border p-8 md:p-12">
        <h2 class="mb-4 text-2xl font-extrabold tracking-[-0.02em]">How does it work?</h2>
        <p class="max-w-[64ch] text-[17px] leading-[1.6] text-ink-soft">
          Photobiomodulation uses light wavelengths in the 620–1000 nm range, which penetrate cells and support their energy metabolism. In practice that means faster recovery and less inflammation in worked tissue.
        </p>
      </div>
    </section>

    <section class="mx-auto max-w-[1220px] px-5 pb-10 md:px-8">
      <h2 class="mb-7 text-2xl font-extrabold tracking-[-0.02em]">What it helps with</h2>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {benefits.map((b) => (
          <div class="rounded-2xl border border-border bg-surface p-7">
            <h3 class="mb-2 text-[19px] font-extrabold tracking-[-0.02em]">{b.t}</h3>
            <p class="text-[15.5px] leading-[1.5] text-ink-soft">{b.d}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="mx-auto max-w-[1220px] px-5 pb-10 md:px-8">
      <div class="max-w-[640px]">
        <h2 class="mb-4 text-2xl font-extrabold tracking-[-0.02em]">How a session works</h2>
        <ul class="flex flex-col gap-3">
          <li class="flex items-start gap-3 text-[16px] text-ink-soft">
            <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
            You come in, lie under the panel, relax — 15 minutes
          </li>
          <li class="flex items-start gap-3 text-[16px] text-ink-soft">
            <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
            Recommended frequency: 3–5× per week for optimal results
          </li>
          <li class="flex items-start gap-3 text-[16px] text-ink-soft">
            <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
            Can be combined with training — ideally as recovery after a class
          </li>
          <li class="flex items-start gap-3 text-[16px] text-ink-soft">
            <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
            Available for members and as a standalone entry
          </li>
        </ul>
      </div>
    </section>

    <section class="mx-auto max-w-[1220px] px-5 pb-10 md:px-8">
      <h2 class="mb-6 text-2xl font-extrabold tracking-[-0.02em]">Pricing</h2>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-2xl border border-border bg-surface p-6">
          <div class="mb-1 text-[32px] font-extrabold tracking-[-0.02em] text-accent-text">13 CZK</div>
          <div class="text-[14px] text-ink-muted">/ minute</div>
          <p class="mt-2 text-[14.5px] text-ink-soft">You pay for the actual time used.</p>
        </div>
        <div class="rounded-2xl border-2 border-accent bg-surface p-6">
          <div class="mb-1 text-[32px] font-extrabold tracking-[-0.02em] text-accent-text">180 CZK</div>
          <div class="text-[14px] text-ink-muted">/ 15 minutes</div>
          <p class="mt-2 text-[14.5px] text-ink-soft">Standard session — the recommended duration for recovery.</p>
        </div>
        <div class="rounded-2xl border border-border bg-surface p-6">
          <div class="mb-1 text-[32px] font-extrabold tracking-[-0.02em] text-accent-text">783 CZK</div>
          <div class="text-[14px] text-ink-muted">/ 60-min pass</div>
          <p class="mt-2 text-[14.5px] text-ink-soft">Bundle of 60 minutes — use them gradually.</p>
        </div>
        <div class="rounded-2xl border border-border bg-surface p-6">
          <div class="mb-1 text-[32px] font-extrabold tracking-[-0.02em]">40 CZK</div>
          <div class="text-[14px] text-ink-muted">protective glasses</div>
          <p class="mt-2 text-[14.5px] text-ink-soft">Recommended for face-area therapy.</p>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-[1220px] px-5 pb-16 md:px-8 md:pb-23">
      <div class="relative flex flex-wrap items-center justify-between gap-6 overflow-hidden rounded-[22px] bg-ink-dark p-8 text-cream md:p-[clamp(32px,5vw,56px)]">
        <div
          class="pointer-events-none absolute -bottom-22 -right-12 h-[340px] w-[340px] rounded-full"
          style="background:radial-gradient(circle, rgba(226,35,26,0.18), rgba(226,35,26,0) 70%);"
          aria-hidden="true"
        ></div>
        <div class="relative">
          <h2 class="max-w-[20ch] text-[clamp(26px,3.4vw,40px)] font-extrabold tracking-[-0.03em]">Want to try it?</h2>
          <p class="mt-3 max-w-[42ch] text-[17px] text-cream-muted">Book a session or write to us — we're happy to advise on how to add photobiomodulation to your programme.</p>
        </div>
        <a
          href="https://bohemi.fit/rezervace/"
          class="relative inline-flex shrink-0 cursor-pointer items-center gap-2 rounded-full bg-accent-text px-7 py-3.5 text-[17px] font-bold text-cream transition-colors hover:bg-accent-deep"
        >
          Book →
        </a>
      </div>
    </section>
  </main>
  <Footer lang="en" />
</Layout>
