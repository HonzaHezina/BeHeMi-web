---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { RESERVE_URL } from '../../data/home.en';

const contactBlocks = [
  { label: 'Address', lines: ['Vinohradská 1438/70', '130 00 Prague 3'] },
  { label: 'Getting here', lines: ['Metro A, trams 11 & 13 — Jiřího z Poděbrad, 2 min walk'] },
  { label: 'Phone', lines: ['+420 603 989 762'], href: 'tel:+420603989762' },
  { label: 'Email', lines: ['info@bohemi.fit'], href: 'mailto:info@bohemi.fit' },
  { label: 'Opening hours', lines: ['Monday — Friday according to class schedule'] },
];

const MAPS_URL = 'https://www.google.com/maps/search/?api=1&query=Vinohradsk%C3%A1%201438%2F70%2C%20Praha%203';
const socials = [
  { label: 'Facebook', href: 'https://www.facebook.com/' },
  { label: 'Instagram', href: 'https://www.instagram.com/' },
];
---
<Layout
  title="Contact — BoHeMi fitness, Vinohrady Prague"
  description="Find us at Vinohradská 1438/70, Prague 3 — two minutes from Jiřího z Poděbrad metro. Write to info@bohemi.fit or call +420 603 989 762."
  lang="en"
  current="/en/contact/"
>
  <Header current="/en/contact/" lang="en" />
  <main>
    <!-- HERO -->
    <section class="relative mx-auto max-w-[1220px] overflow-hidden px-5 pb-10 pt-16 md:px-8 md:pt-20">
      <div
        class="pointer-events-none absolute right-0 top-0 h-[400px] w-[400px] rounded-full"
        style="background:radial-gradient(circle, rgba(226,35,26,0.11), rgba(226,35,26,0) 70%);"
        aria-hidden="true"
      >
      </div>
      <div class="relative">
        <h1 class="text-[clamp(40px,6.2vw,76px)] font-extrabold leading-[0.98] tracking-[-0.035em]">
          Find us near <span class="font-medium text-accent-text">Jiřák</span>
        </h1>
        <p class="mt-6 max-w-[52ch] text-[clamp(18px,2.1vw,22px)] leading-[1.45] text-ink-warm">
          Vinohradská 1438/70, Prague 3. Two minutes on foot from Jiřího z Poděbrad metro and tram stop.
        </p>
      </div>
    </section>

    <!-- DETAILS + MAP / ACTIONS -->
    <section class="mx-auto grid max-w-[1220px] gap-10 px-5 pb-16 md:grid-cols-2 md:px-8 md:pb-23">
      <!-- Column: contact info -->
      <div>
        <div class="mb-8 flex flex-col gap-7">
          {contactBlocks.map((b) => (
            <div>
              <div class="mb-2 text-[13px] font-bold uppercase tracking-[0.06em] text-ink-faint">{b.label}</div>
              {b.href ? (
                <a href={b.href} class="text-[19px] leading-[1.5] text-ink hover:text-brand">{b.lines[0]}</a>
              ) : (
                <div class="text-[19px] leading-[1.5] text-ink">
                  {b.lines.map((l, i) => (<>{i > 0 && <br />}{l}</>))}
                </div>
              )}
            </div>
          ))}
        </div>
        <div class="flex flex-wrap gap-3">
          {socials.map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-full border-[1.5px] border-border-button px-[18px] py-2.5 text-[15px] font-semibold text-ink-line transition-colors hover:border-brand hover:text-brand"
            >
              {s.label}
            </a>
          ))}
        </div>
      </div>

      <!-- Column: map + actions -->
      <div>
        <a
          href={MAPS_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="group relative mb-6 block h-60 overflow-hidden rounded-[18px] media-green"
          aria-label="Open BoHeMi address in Google Maps"
        >
          <div
            class="absolute inset-0"
            style="background-image:repeating-linear-gradient(0deg, rgba(255,255,255,0.10) 0 1px, transparent 1px 30px),repeating-linear-gradient(90deg, rgba(255,255,255,0.10) 0 1px, transparent 1px 30px);"
            aria-hidden="true"
          >
          </div>
          <span class="absolute bottom-4 left-4 inline-flex items-center gap-2 rounded-full bg-ink-dark/55 px-3.5 py-1.5 text-[13px] font-semibold text-cream backdrop-blur-sm transition-colors group-hover:bg-ink-dark/75">
            Open in Maps ↗
          </span>
        </a>

        <div class="rounded-[18px] border border-border bg-surface p-7">
          <h2 class="mb-2 text-[21px] font-extrabold tracking-[-0.02em]">Write to us</h2>
          <p class="mb-5 text-[15.5px] leading-[1.55] text-ink-soft">Questions about classes, the 8-Week Program or corporate training? Write or call — we'll get back to you.</p>
          <div class="flex flex-col gap-3">
            <a
              href="mailto:info@bohemi.fit"
              class="inline-flex cursor-pointer items-center justify-center gap-2 rounded-full bg-accent-text px-6 py-3.5 text-base font-bold text-cream transition-colors hover:bg-accent-deep focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-surface"
            >
              Send an email
            </a>
            <a
              href="tel:+420603989762"
              class="inline-flex cursor-pointer items-center justify-center gap-2 rounded-full border-[1.5px] border-border-button px-6 py-3.5 text-base font-bold text-ink transition-colors hover:border-brand hover:text-brand"
            >
              Call +420 603 989 762
            </a>
          </div>
          <p class="mt-5 border-t border-border pt-5 text-[15px] leading-[1.55] text-ink-soft">
            Ready to book a class or join the next 8-Week Program?
            <a href={RESERVE_URL} target="_blank" rel="noopener noreferrer" class="font-semibold text-accent-text hover:text-accent-deep">Book online ↗</a>
          </p>
        </div>
      </div>
    </section>
  </main>
  <Footer lang="en" />
</Layout>
