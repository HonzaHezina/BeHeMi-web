---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import MediaFrame from '../components/MediaFrame.astro';
import { Image } from 'astro:assets';
import { RESERVE_URL, trainers } from '../data/home';
import { trainerPhotos } from '../data/trainer-photos';

// Jen trenéři, kteří nabízí osobní tréninky (Klára Měchurová).
// Ostatní lektoři vedou skupinové lekce — nepřidávat sem bez potvrzení.
const ptTrainer = trainers.find((t) => t.name === 'Klára Měchurová');

const whatYouGet = [
  'Tréninkový plán přizpůsobený tvému tělu, tempu a cílům',
  'Přizpůsobení cvičení zdravotním omezením nebo po pauze',
  'Pravidelná zpětná vazba a průběžné úpravy plánu',
  'Flexibilní termíny domluvené přímo s trenérem',
  'Jako člen BoHeMi máš 30% slevu na každý osobní trénink',
];
---
<Layout
  title="Osobní tréninky — BoHeMi fitness Vinohrady"
  description="Individuální osobní tréninky s certifikovanou trenérkou v BoHeMi na pražských Vinohradech. Trénink přizpůsobený tvým cílům, zdraví a tempu. Cena 800–1 500 Kč."
>
  <Header current="/osobni-treninky/" />
  <main>
    <!-- HERO -->
    <section class="relative mx-auto max-w-[1220px] overflow-hidden px-5 pb-8 pt-16 md:px-8 md:pt-20">
      <div
        class="pointer-events-none absolute right-0 top-2.5 h-[400px] w-[400px] rounded-full"
        style="background:radial-gradient(circle, rgba(226,35,26,0.12), rgba(226,35,26,0) 70%);"
        aria-hidden="true"
      ></div>
      <div class="relative max-w-[720px]">
        <p class="mb-4 text-[13px] font-extrabold uppercase tracking-[0.08em] text-accent-text">
          <a href="/lekce-a-sluzby/" class="hover:text-ink">Lekce a služby</a> · Pro tebe
        </p>
        <h1 class="text-[clamp(40px,6.2vw,76px)] font-extrabold leading-[0.98] tracking-[-0.035em]">
          Osobní <span class="font-medium italic text-accent-text">tréninky</span>
        </h1>
        <p class="mt-6 max-w-[56ch] text-[clamp(18px,2.1vw,22px)] leading-[1.45] text-ink-warm">
          Skupinové lekce ti nevyhovují nebo chceš víc individuálního přístupu?
          Osobní trénink jde přesně za tvým cílem — nic víc, nic míň.
        </p>
      </div>
    </section>

    <!-- CO DOSTANEŠ + FOTO -->
    <section class="mx-auto max-w-[1220px] px-5 pt-6 md:px-8">
      <div class="grid gap-6 overflow-hidden rounded-[22px] border border-border bg-surface lg:grid-cols-[1.1fr_0.9fr]">
        <div class="p-8 md:p-10">
          <h2 class="mb-3 text-[clamp(26px,3.2vw,38px)] font-extrabold leading-[1.06] tracking-[-0.03em]">Co osobní trénink obnáší</h2>
          <p class="mb-5 max-w-[54ch] text-[17px] leading-[1.55] text-ink-soft">
            Trenér se ti věnuje celou lekci — opravuje techniku, nastaví zátěž a průběžně upravuje
            plán podle toho, jak se cítíš a jak pokračuješ. Žádný obecný program ze šablony.
          </p>
          <ul class="mb-7 flex flex-col gap-2.5">
            {whatYouGet.map((item) => (
              <li class="flex items-start gap-2.5 text-[15.5px] text-ink-line">
                <span class="mt-[7px] h-1.5 w-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
          <div class="flex flex-wrap items-center gap-5">
            <Button href="mailto:info@bohemi.fit" variant="brand">Domluvit první trénink →</Button>
            <a href="/cenik/" class="cursor-pointer text-[15px] font-bold text-accent-text hover:text-ink">Ceník →</a>
          </div>
        </div>
        <MediaFrame media="media-green" rounded="rounded-none" class="min-h-[240px] lg:min-h-full" alt="Osobní trénink v BoHeMi — individuální přístup trenérky">
          <Image
            src={trainerPhotos['Klára Měchurová']}
            alt="Osobní trénink v BoHeMi — individuální přístup trenérky"
            class="h-full w-full object-cover"
            widths={[640, 1024]}
            sizes="(min-width: 1024px) 45vw, 100vw"
            loading="eager"
          />
        </MediaFrame>
      </div>
    </section>

    <!-- CENA -->
    <section class="mx-auto max-w-[1220px] px-5 pt-10 md:px-8">
      <div class="flex flex-wrap gap-5">
        <div class="flex-1 min-w-[240px] rounded-[18px] border border-border bg-surface p-7">
          <p class="mb-1 text-[13px] font-extrabold uppercase tracking-[0.08em] text-ink-muted">Cena tréninku</p>
          <p class="text-[clamp(28px,3.5vw,40px)] font-extrabold tracking-[-0.03em]">800–1 500 Kč</p>
          <p class="mt-2 text-[15px] text-ink-soft">za lekci — záleží na délce spolupráce a frekvenci</p>
        </div>
        <div class="flex-1 min-w-[240px] rounded-[18px] border border-border bg-surface p-7">
          <p class="mb-1 text-[13px] font-extrabold uppercase tracking-[0.08em] text-ink-muted">Sleva pro členy</p>
          <p class="text-[clamp(28px,3.5vw,40px)] font-extrabold tracking-[-0.03em] text-accent-text">−30 %</p>
          <p class="mt-2 text-[15px] text-ink-soft">na každý osobní trénink jako benefit členství BoHeMi</p>
        </div>
      </div>
    </section>

    <!-- TRENÉR -->
    {ptTrainer && (
      <section class="mx-auto max-w-[1220px] px-5 pt-10 md:px-8">
        <h2 class="mb-6 text-[clamp(24px,3vw,34px)] font-extrabold tracking-[-0.03em]">Kdo tě povede</h2>
        <div class="flex gap-7 overflow-hidden rounded-[22px] border border-border bg-surface p-8 flex-col sm:flex-row items-start">
          <div class="shrink-0 w-24 h-24 rounded-full overflow-hidden">
            {trainerPhotos[ptTrainer.name] ? (
              <MediaFrame media={ptTrainer.media} rounded="rounded-full" class="w-24 h-24" alt={`Portrét — ${ptTrainer.name}`}>
                <Image
                  src={trainerPhotos[ptTrainer.name]}
                  alt={`Portrét — ${ptTrainer.name}`}
                  class="h-full w-full object-cover"
                  widths={[96, 192]}
                  sizes="96px"
                />
              </MediaFrame>
            ) : (
              <MediaFrame media={ptTrainer.media} rounded="rounded-full" class="w-24 h-24" alt={`Portrét — ${ptTrainer.name}`} />
            )}
          </div>
          <div>
            <h3 class="text-[21px] font-extrabold tracking-[-0.02em]">{ptTrainer.name}</h3>
            <p class="mb-3 text-[14px] font-bold uppercase tracking-[0.06em] text-accent-text">{ptTrainer.role}</p>
            {ptTrainer.bio && <p class="max-w-[60ch] text-[15.5px] leading-[1.55] text-ink-soft">{ptTrainer.bio}</p>}
            <p class="mt-4">
              <a href="/treneri/" class="text-[15px] font-bold text-accent-text hover:text-ink">Celý tým →</a>
            </p>
          </div>
        </div>
      </section>
    )}

    <!-- CTA -->
    <section class="mx-auto max-w-[1220px] px-5 pb-16 pt-10 md:px-8 md:pb-23">
      <div class="relative flex flex-wrap items-center justify-between gap-6 overflow-hidden rounded-[22px] bg-ink-dark p-8 text-cream md:p-[clamp(32px,5vw,56px)]">
        <div
          class="pointer-events-none absolute -bottom-22 -right-12 h-[340px] w-[340px] rounded-full"
          style="background:radial-gradient(circle, rgba(226,35,26,0.18), rgba(226,35,26,0) 70%);"
          aria-hidden="true"
        ></div>
        <div class="relative">
          <h2 class="max-w-[22ch] text-[clamp(26px,3.4vw,40px)] font-extrabold tracking-[-0.03em]">Zajímají tě osobní tréninky?</h2>
          <p class="mt-3 max-w-[44ch] text-[17px] text-cream-muted">Napiš nám — domluvíme první konzultaci zdarma a ukážeme ti, jak to funguje.</p>
        </div>
        <a
          href="mailto:info@bohemi.fit"
          class="relative inline-flex shrink-0 cursor-pointer items-center gap-2 rounded-full bg-accent-text px-7 py-3.5 text-[17px] font-bold text-cream transition-colors hover:bg-accent-deep"
        >
          Napsat nám →
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
