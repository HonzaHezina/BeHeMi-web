---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Button from '../components/Button.astro';

// Obsah z exportu (PROC). Odkaz na konkrétní knihu / PDF vynechán a sekce
// „Rámec a praxe" zmírněna — konzistentně s rozhodnutím u homepage.
const teacher = [
  { k: 'Kruháč', d: 'Učí dotahovat věci do konce. Stanoviště za stanovištěm, bez výmluv.' },
  { k: 'Žonglování', d: 'Učí soustředění, rytmus a trpělivost — a schopnost lépe číst vzorce.' },
  { k: 'Dech', d: 'Učí zklidnit se a vrátit pozornost zpátky k tělu.' },
  { k: 'Síla', d: 'Učí trpělivosti a tomu, že pokrok je pomalý, ale poctivý.' },
];

const principleMap = [
  { princip: 'Filozofie zdraví', bohemi: 'Živé lekce a vedená praxe' },
  { princip: 'Health tracker', bohemi: 'Skupina, trenér, pravidelnost' },
  { princip: 'Denní rutina', bohemi: 'Konkrétní pohybové programy' },
  { princip: 'Tělo i vnitřní nastavení', bohemi: 'Práce s tělem v reálném prostoru' },
  { princip: 'Rodina, společnost, příroda', bohemi: 'Supermamky, děti, komunita, firmy' },
  { princip: 'Vzdělávání', bohemi: 'Česká civilní aplikace v životě' },
];
---
<Layout
  title="Proč BoHeMi — tělo jako škola života"
  description="Příběh BoHeMi: pohyb, který nekončí u svalů. Jak se přes tělo otevírá cesta k hlavě, návykům, dechu a klidu — a proč to děláme jako komunitu na Vinohradech."
>
  <Header current="/proc-bohemi/" />
  <main>
    <!-- HERO -->
    <section class="relative mx-auto max-w-[1100px] overflow-hidden px-5 pb-12 pt-16 md:px-8 md:pt-20">
      <div
        class="pointer-events-none absolute right-0 top-0 h-[420px] w-[420px] rounded-full"
        style="background:radial-gradient(circle, rgba(194,105,63,0.14), rgba(194,105,63,0) 70%);"
        aria-hidden="true"
      >
      </div>
      <div class="relative">
        <Eyebrow>Proč BoHeMi</Eyebrow>
        <h1 class="max-w-[15ch] text-[clamp(40px,6.2vw,76px)] font-extrabold leading-[0.98] tracking-[-0.035em]">
          Tělo jako <span class="font-medium italic text-brand">škola života.</span>
        </h1>
        <p class="mt-5 text-[clamp(19px,2.2vw,24px)] font-semibold text-brand">Pohyb, který nekončí u svalů.</p>
      </div>
    </section>

    <!-- STORY -->
    <section class="mx-auto max-w-[860px] px-5 pb-6 md:px-8">
      <div class="flex flex-col gap-5 text-[19px] leading-[1.6] text-ink-line">
        <p>BoHeMi vzniklo z osobní zkušenosti, že pohyb není jen fyzická aktivita. Když jsem se začal pravidelně hýbat, postupně se neměnilo jen tělo — měnila se i schopnost soustředit se, dokončovat věci a zvládat stres.</p>
        <p>Kruhové tréninky mě naučily dotahovat věci do konce. Žonglování trpělivosti, rytmu, pozornosti a schopnosti lépe číst vzorce. Postupně mi došlo, že přes tělo se dá otevřít cesta i k hlavě, návykům a rovnováze.</p>
        <p>Postupně se z toho složil jednoduchý rámec pro něco, co jsem už v praxi cítil: člověk není jen tělo, ale tělem začíná naše každodenní zkušenost se světem.</p>
      </div>
      <figure class="mt-9 border-y border-border-strong py-8">
        <blockquote class="text-[clamp(24px,3vw,34px)] italic leading-[1.3] tracking-[-0.015em] text-brand-dark">„Přes tělo jsem se začal učit věci, které mi pak pomohly i v práci a životě.“</blockquote>
        <figcaption class="mt-4 text-[15px] text-ink-muted">— Jan Hezina, zakladatel BoHeMi</figcaption>
      </figure>
    </section>

    <!-- TĚLO JAKO UČITEL -->
    <section class="mx-auto max-w-[1100px] px-5 py-14 md:px-8 md:py-15">
      <h2 class="mb-9 text-[clamp(28px,3.6vw,44px)] font-extrabold tracking-[-0.03em]">Tělo jako <span class="font-medium italic text-brand">učitel.</span></h2>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {teacher.map((t) => (
          <div class="rounded-[18px] border border-border bg-surface px-[26px] py-[30px] transition-all duration-300 hover:-translate-y-1.5 hover:border-brand hover:shadow-[0_22px_44px_-20px_rgba(33,31,26,0.26)]">
            <h3 class="mb-2 text-[22px] font-extrabold tracking-[-0.02em] text-brand">{t.k}</h3>
            <p class="text-base leading-[1.5] text-ink-soft">{t.d}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- RÁMEC A PRAXE (zmírněno — bez konkrétní knihy / odkazu) -->
    <section class="relative overflow-hidden bg-ink-dark text-cream">
      <div
        class="pointer-events-none absolute -bottom-22 -left-16 h-[440px] w-[440px] rounded-full"
        style="background:radial-gradient(circle, rgba(47,90,64,0.5), rgba(47,90,64,0) 70%);"
        aria-hidden="true"
      >
      </div>
      <div class="relative mx-auto max-w-[1100px] px-5 py-20 md:px-8">
        <p class="mb-3 italic text-[23px] text-sage">Rámec a praxe</p>
        <h2 class="mb-3.5 max-w-[20ch] text-[clamp(28px,3.8vw,46px)] font-extrabold leading-[1.04] tracking-[-0.03em]">Z principů děláme každodenní praxi.</h2>
        <p class="mb-10 max-w-[54ch] text-lg text-cream-soft">Na zdraví se díváme jako na harmonii těla, mysli, vztahů a prostředí — a převádíme ji do živé, české a civilní praxe. Nic nebereme jako dogma; co navrhujeme, si ověříš na vlastní energii.</p>

        <div class="overflow-hidden rounded-2xl border border-border-dark">
          <div class="grid grid-cols-2 bg-white/5">
            <div class="px-6 py-3.5 text-[13px] font-bold uppercase tracking-[0.06em] text-sage">Princip</div>
            <div class="border-l border-border-dark px-6 py-3.5 text-[13px] font-bold uppercase tracking-[0.06em] text-clay-soft">BoHeMi v praxi</div>
          </div>
          {principleMap.map((m) => (
            <div class="grid grid-cols-2 border-t border-border-dark">
              <div class="px-6 py-4 text-base text-cream-soft">{m.princip}</div>
              <div class="border-l border-border-dark px-6 py-4 text-base font-semibold text-cream">{m.bohemi}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- PŘECHOD -->
    <section class="mx-auto max-w-[860px] px-5 pb-6 pt-6 md:px-8">
      <p class="text-lg leading-[1.6] text-ink-soft">Jen pravidelný pohyb, dech, regenerace a komunita — praxe, kterou si sám ověříš na vlastní energii, a lidi, co to spolu žijí.</p>
    </section>

    <!-- CTA -->
    <section class="mx-auto max-w-[1100px] px-5 pb-20 pt-8 text-center md:px-8">
      <h2 class="mx-auto mb-5 max-w-[20ch] text-[clamp(28px,4vw,46px)] font-extrabold tracking-[-0.035em]">Začni tělem. Pokračuj praxí.</h2>
      <p class="mx-auto mb-7 max-w-[44ch] text-lg text-ink-soft">Nejjednodušší první krok je přijít na lekci nebo se přidat do příští skupiny programu Cesta.</p>
      <div class="flex flex-wrap justify-center gap-3.5">
        <Button href="/#cesta" variant="brand">Cesta →</Button>
        <Button href="/lekce-a-sluzby/" variant="outline">Rozvrh lekcí</Button>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
