---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import MediaFrame from '../components/MediaFrame.astro';
import { Image } from 'astro:assets';
import { trainers, RESERVE_URL } from '../data/home';
import { trainerPhotos } from '../data/trainer-photos';

// Bohatší obsah (co kdo vede — odkazy na kotvy) žije jen tady, stejný vzor
// jako lessons[] v /skupinove-lekce/.astro. Krátké karty pro HP zůstávají
// v trainers[] v src/data/home.ts — tahle stránka je detail, HP jen ochutnávka.
// Odkazy vycházet jen z toho, co je potvrzené (bio, nebo atribuce lekce na
// /skupinove-lekce/) — nevymýšlet, co kdo vede.
const leads: Record<string, { t: string; href: string }[]> = {
  'klara-mechurova': [
    { t: 'Kruhový trénink', href: '/skupinove-lekce/#kruhac' },
    { t: 'Silové tréninky', href: '/skupinove-lekce/#silovy-trenink' },
    { t: 'HIIT', href: '/skupinove-lekce/#hiit' },
    { t: 'Osobní tréninky', href: '/osobni-treninky/' },
  ],
  'jitka-stepankova': [
    { t: 'Power Zone', href: '/skupinove-lekce/#power-zone' },
  ],
  'eliska-velazquez': [
    { t: 'Zumba', href: '/skupinove-lekce/#zumba' },
    { t: 'Dětská Zumba', href: '/krouzky-pro-deti/#detska-zumba' },
  ],
};
---
<Layout
  title="Trenéři — BoHeMi fitness Vinohrady"
  description="Tým BoHeMi fitness na pražských Vinohradech. Klára Měchurová, Jitka Štěpánková, Eliška Velázquez a Jan Hezina — lidé, kteří za studiem stojí."
>
  <Header current="/treneri/" />
  <main>
    <!-- HERO + kotvy-menu -->
    <section class="relative mx-auto max-w-[1220px] overflow-hidden px-5 pb-10 pt-16 md:px-8 md:pt-20">
      <div
        class="pointer-events-none absolute right-0 top-2.5 h-[400px] w-[400px] rounded-full"
        style="background:radial-gradient(circle, rgba(226,35,26,0.12), rgba(226,35,26,0) 70%);"
        aria-hidden="true"
      ></div>
      <div class="relative max-w-[680px]">
        <p class="mb-4 text-[13px] font-extrabold uppercase tracking-[0.08em] text-accent-text">
          <a href="/proc-bohemi/" class="hover:text-ink">Proč BoHeMi</a> · Tým
        </p>
        <h1 class="text-[clamp(40px,6.2vw,76px)] font-extrabold leading-[0.98] tracking-[-0.035em]">
          Náš <span class="font-medium text-accent-text">tým</span>
        </h1>
        <p class="mt-6 max-w-[54ch] text-[clamp(18px,2.1vw,22px)] leading-[1.45] text-ink-warm">
          Lektoři a zakladatel studia. Malé skupiny, přímý kontakt, žádná anonymita.
        </p>
      </div>
      <nav aria-label="Rychlá navigace na trenéry" class="relative mt-8 flex flex-wrap gap-2.5">
        {trainers.map((tr) => (
          <a href={`#${tr.id}`} class="cursor-pointer rounded-full border-[1.5px] border-border-button px-[18px] py-2.5 text-[14.5px] font-bold text-ink-line transition-colors hover:border-brand hover:text-brand">{tr.name}</a>
        ))}
      </nav>
    </section>

    <!-- TRENÉŘI -->
    <section class="mx-auto max-w-[1220px] px-5 md:px-8" aria-label="Přehled trenérů">
      <div class="space-y-6">
        {trainers.map((tr) => (
          <article id={tr.id} class="scroll-mt-24 overflow-hidden rounded-2xl border border-border bg-surface md:grid md:grid-cols-[minmax(240px,320px)_1fr]">
            {trainerPhotos[tr.name] ? (
              <MediaFrame media={tr.media} rounded="rounded-none" class="h-60 md:h-full" alt={`Portrét — ${tr.name}`}>
                <Image
                  src={trainerPhotos[tr.name]}
                  alt={`Portrét — ${tr.name}`}
                  class="h-full w-full object-cover"
                  widths={[320, 640]}
                  sizes="(min-width: 768px) 320px, 100vw"
                  loading="lazy"
                />
              </MediaFrame>
            ) : (
              <MediaFrame media={tr.media} rounded="rounded-none" class="h-60 md:h-full" alt={`Portrét — ${tr.name}`} />
            )}
            <div class="p-7 md:p-9">
              <h2 class="text-[clamp(22px,2.6vw,28px)] font-extrabold tracking-[-0.02em]">{tr.name}</h2>
              <p class="mt-2 text-[13px] font-extrabold uppercase tracking-[0.06em] text-accent-text">{tr.role}</p>
              {tr.bio
                ? <p class="mt-4 max-w-[68ch] text-[15.5px] leading-[1.55] text-ink-soft">{tr.bio}</p>
                : <p class="mt-4 text-[15.5px] text-ink-muted">Profil brzy doplníme.</p>
              }
              {leads[tr.id] && (
                <div class="mt-5 flex flex-wrap items-center gap-2">
                  <span class="text-[13.5px] font-bold text-ink-muted">Co vede:</span>
                  {leads[tr.id].map((l) => (
                    <a href={l.href} class="cursor-pointer rounded-full border-[1.5px] border-border-button px-3.5 py-1.5 text-[13.5px] font-bold text-ink-line transition-colors hover:border-brand hover:text-brand">{l.t}</a>
                  ))}
                </div>
              )}
            </div>
          </article>
        ))}
      </div>

      <!-- Nabídka osobních tréninků -->
      <div class="mt-12 rounded-[22px] bg-sand p-8 md:p-10">
        <h2 class="mb-3 text-[clamp(22px,2.8vw,30px)] font-extrabold tracking-[-0.02em]">Chceš individuální pozornost?</h2>
        <p class="mb-6 max-w-[58ch] text-[16px] leading-[1.6] text-ink-soft">
          Někteří lektoři nabízí kromě skupinových lekcí i osobní tréninky.
          Domluvíte si termín a program přímo s trenérem.
        </p>
        <div class="flex flex-wrap gap-4">
          <Button href="/osobni-treninky/" variant="brand">Osobní tréninky →</Button>
          <Button href={RESERVE_URL} variant="outline" external>Skupinové lekce</Button>
        </div>
      </div>
    </section>

    <div class="pb-16 md:pb-23"></div>
  </main>
  <Footer />
</Layout>
