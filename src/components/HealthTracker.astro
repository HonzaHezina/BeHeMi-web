---
import { bodyPurpose as bodyPurposeCS } from "../data/home";
import { bodyPurpose as bodyPurposeEN } from "../data/home.en";
import type { Lang } from '../i18n/ui';
import { t } from '../i18n/ui';

interface Props {
  lang?: Lang;
}
const { lang = 'cs' } = Astro.props;
const bodyPurpose = lang === 'en' ? bodyPurposeEN : bodyPurposeCS;
---
<section class="relative overflow-hidden bg-ink-dark text-cream">
  <div
    class="pointer-events-none absolute -right-18 -top-22 h-[440px] w-[440px] rounded-full"
    style="background:radial-gradient(circle, rgba(226,35,26,0.14), rgba(226,35,26,0) 70%);"
    aria-hidden="true"
  >
  </div>
  <div class="relative mx-auto max-w-[1220px] px-5 py-16 md:px-8 md:py-23">
    <div class="grid items-center gap-11 md:grid-cols-2 lg:gap-13">
      <div>
        <span class="mb-5 inline-block rounded-full bg-white/15 px-3.5 py-1.5 text-[13px] font-bold uppercase tracking-[0.04em] text-cream">
          {t(lang, 'ht_badge')}
        </span>
        <h2 class="mb-[18px] text-[clamp(30px,4vw,50px)] font-extrabold leading-[1.02] tracking-[-0.03em]">
          {t(lang, 'ht_h2_a')} <span class="font-medium text-accent">{t(lang, 'ht_h2_b')}</span>
        </h2>
        <p class="mb-5 max-w-[46ch] text-lg leading-[1.55] text-mint-text">
          {t(lang, 'ht_body_1')}
        </p>
        <p class="max-w-[46ch] text-lg leading-[1.55] text-mint-text">
          {t(lang, 'ht_body_2')}
        </p>
      </div>
      <div class="overflow-hidden rounded-[18px] bg-surface shadow-[0_24px_50px_-22px_rgba(0,0,0,0.5)]">
        <div class="border-b border-tracker-line px-6 py-4">
          <span class="text-[12px] font-bold uppercase tracking-[0.06em] text-ink-faint">
            {lang === 'en' ? 'What changes when you start exercising regularly' : 'Co se změní, když začneš pravidelně cvičit'}
          </span>
        </div>
        {bodyPurpose.map((item) => (
          <div class="flex items-center gap-[18px] border-b border-tracker-line px-6 py-[18px] last:border-b-0">
            <span class="flex h-[22px] w-[22px] shrink-0 items-center justify-center rounded-full bg-accent/12 text-[13px] font-extrabold text-accent-text" aria-hidden="true">✓</span>
            <span class="text-[15px] leading-snug text-ink-line">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
