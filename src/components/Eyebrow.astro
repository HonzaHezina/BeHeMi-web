---
// Akcentový "eyebrow" nadpisek nad sekcí.
// Bez serifu — odlišení jen barvou (rozhodnutí 7/2026: žádná kurzíva).
interface Props {
  color?: 'accent' | 'faint' | 'brand-tint' | 'sage';
  class?: string;
}
const { color = 'accent', class: extra = '' } = Astro.props;
const colors: Record<string, string> = {
  accent: 'text-accent-text',
  faint: 'text-ink-faint',
  'brand-tint': 'text-brand-tint',
  sage: 'text-sage-soft', // pro tmavé pozadí
};
---
<p class={`font-medium text-[23px] mb-2.5 ${colors[color]} ${extra}`}>
  <slot />
</p>
