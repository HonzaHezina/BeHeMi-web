---
import { nav, navMenu, RESERVE_URL } from '../data/home';
import Button from './Button.astro';

interface Props {
  current?: string;
}
const { current = '/' } = Astro.props;
---
<header class="sticky top-0 z-50 border-b border-border-strong bg-bg/80 backdrop-blur-md">
  <div class="mx-auto flex max-w-[1220px] items-center justify-between gap-6 px-5 py-3.5 md:px-8">
    <!-- Logo -->
    <a href="/" class="flex items-baseline gap-2.5 cursor-pointer">
      <span class="text-[27px] font-extrabold tracking-tight text-ink">BoHeMi</span>
      <span class="hidden italic text-[15px] text-brand sm:inline">Body · Health · Mind</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-0.5 lg:flex" aria-label="Hlavní navigace">
      {nav.map((item) => (
        item.href === '/lekce-a-sluzby/' ? (
          <div class="group relative">
            <a
              href={item.href}
              class="relative flex items-center gap-1.5 px-3.5 py-2 text-[15.5px] font-semibold tracking-tight text-ink-line hover:text-brand"
            >
              {item.label}
              <svg class="h-2.5 w-2.5 opacity-55" viewBox="0 0 10 6" fill="none" aria-hidden="true">
                <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
            <div
              class="invisible absolute left-1/2 top-[calc(100%+6px)] z-60 w-[312px] -translate-x-1/2 rounded-2xl border border-border bg-surface p-2 opacity-0 shadow-[0_22px_48px_-16px_rgba(33,31,26,0.3)] transition-opacity duration-150 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100"
            >
              {navMenu.map((m) => (
                <a href={m.href} class="flex items-start gap-3.5 rounded-xl p-3.5 transition-colors hover:bg-surface-hover">
                  <span class="shrink-0 italic text-lg leading-tight text-accent-text">{m.num}</span>
                  <span>
                    <span class="block text-base font-bold tracking-tight text-ink">{m.label}</span>
                    <span class="mt-0.5 block text-[13.5px] text-ink-muted">{m.desc}</span>
                  </span>
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={item.href}
            aria-current={item.href === current ? 'page' : undefined}
            class="relative px-3.5 py-2 text-[15.5px] font-semibold tracking-tight text-ink-line hover:text-brand"
          >
            {item.label}
            {item.href === current && <span class="absolute inset-x-3.5 bottom-0.5 h-0.5 rounded-full bg-accent"></span>}
          </a>
        )
      ))}

      <Button href={RESERVE_URL} variant="brand" external class="ml-3.5 px-[22px] py-2.5 text-[15px]">Rezervovat</Button>
    </nav>

    <!-- Mobile -->
    <div class="flex items-center gap-3 lg:hidden">
      <Button href={RESERVE_URL} variant="brand" external class="px-4 py-2 text-sm">Rezervovat</Button>
      <details class="group relative">
        <summary class="flex h-10 w-10 cursor-pointer list-none items-center justify-center rounded-full border border-border-strong text-ink [&::-webkit-details-marker]:hidden" aria-label="Otevřít menu">
          <svg class="h-5 w-5 group-open:hidden" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round" /></svg>
          <svg class="hidden h-5 w-5 group-open:block" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" /></svg>
        </summary>
        <nav class="absolute right-0 top-[calc(100%+10px)] w-[260px] rounded-2xl border border-border bg-surface p-3 shadow-[0_22px_48px_-16px_rgba(33,31,26,0.3)]" aria-label="Mobilní navigace">
          {nav.map((item) => (
            <a href={item.href} class="block rounded-xl px-4 py-3 text-base font-semibold text-ink-line hover:bg-surface-hover">{item.label}</a>
          ))}
          <div class="my-1 border-t border-border"></div>
          {navMenu.map((m) => (
            <a href={m.href} class="block rounded-xl px-4 py-2.5 text-[15px] text-ink-soft hover:bg-surface-hover">{m.label}</a>
          ))}
        </nav>
      </details>
    </div>
  </div>
</header>
