---
import Eyebrow from './Eyebrow.astro';
import { pricing as pricingCS } from '../data/home';
import { pricing as pricingEN } from '../data/home.en';
import type { Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}
const { lang = 'cs' } = Astro.props;
const pricing = lang === 'en' ? pricingEN : pricingCS;
const pricingHref = lang === 'en' ? '/en/pricing/' : '/cenik/';
---
<section id="cenik" class="mx-auto max-w-[1220px] scroll-mt-24 px-5 py-16 md:px-8 md:py-23">
  <div class="mb-10 flex flex-wrap items-end justify-between gap-4">
    <div>
      <Eyebrow>{lang === 'en' ? 'Pricing' : 'Za kolik to máme'}</Eyebrow>
      <h2 class="text-[clamp(30px,4vw,48px)] font-extrabold tracking-[-0.03em]">
        {lang === 'en' ? 'Choose based on how often you want to come.' : 'Vyber podle toho, jak často chceš chodit.'}
      </h2>
    </div>
    <a href={pricingHref} class="cursor-pointer text-base font-bold text-accent-text hover:text-ink">
      {lang === 'en' ? 'Full pricing →' : 'Celý ceník →'}
    </a>
  </div>

  <div class="grid gap-5 md:grid-cols-3">
    {pricing.map((pl) => (
      <div class={`relative flex flex-col rounded-[18px] border bg-surface p-8 ${pl.featured ? 'border-2 border-accent' : 'border-border'}`}>
        {pl.badge && (
          <span class="absolute -top-2.5 left-8 rounded-full bg-accent-text px-3.5 py-1.5 text-xs font-bold uppercase tracking-[0.04em] text-cream">{pl.badge}</span>
        )}
        <h3 class="mb-1 text-[23px] font-extrabold tracking-[-0.02em]">{pl.t}</h3>
        <p class="mb-4 text-[15px] text-ink-muted">{pl.d}</p>
        <div class="mb-1.5 flex items-baseline gap-1.5">
          <span class="text-[34px] font-extrabold tracking-[-0.02em]">{pl.price}</span>
          <span class="text-[15px] text-ink-muted">{pl.per}</span>
        </div>
        <p class="mb-4 min-h-[18px] text-[13.5px] font-semibold text-accent-text">{pl.note}</p>
        <ul class="mt-auto flex flex-col gap-2.5">
          {pl.feat.map((f) => (
            <li class="flex items-start gap-2.5 text-[15.5px] text-ink-line">
              <span class="mt-[7px] h-1.5 w-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
              <span>{f}</span>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>
