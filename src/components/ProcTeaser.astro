---
import Eyebrow from './Eyebrow.astro';
import Button from './Button.astro';
import MediaFrame from './MediaFrame.astro';
---
<section id="proc" class="mx-auto max-w-[1220px] px-5 pb-16 md:px-8 md:pb-23">
  <div class="grid items-center gap-11 rounded-3xl border border-mint-border bg-mint p-9 md:grid-cols-2 md:p-[clamp(36px,5vw,60px)]">
    <div>
      <Eyebrow>Proč BoHeMi</Eyebrow>
      <h2 class="mb-[18px] text-[clamp(28px,3.6vw,44px)] font-extrabold leading-[1.04] tracking-[-0.03em]">Tělo jako škola života.</h2>
      <p class="mb-4 max-w-[48ch] text-lg leading-[1.55] text-ink-line">BoHeMi vzniklo z osobní zkušenosti, že pohyb nemění jen tělo. Kruhové tréninky mě naučily dotahovat věci do konce, žonglování soustředění a trpělivosti — a to se přeneslo do práce i života.</p>
      <p class="mb-[26px] max-w-[44ch] text-xl italic leading-[1.35] text-ink">„Nejsme jen tělo. Ale tělo je nejpoctivější místo, kde začít.“</p>
      <Button href="/proc-bohemi/" variant="brand">Náš příběh →</Button>
    </div>
    <MediaFrame
      media="media-green"
      rounded="rounded-[18px] rounded-tr-[130px]"
      class="h-[clamp(240px,28vw,330px)] w-full"
      alt="Žonglování a komunita v BoHeMi"
    />
  </div>
</section>
