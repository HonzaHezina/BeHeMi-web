---
import { RESERVE_URL } from '../data/home';
import type { Lang } from '../i18n/ui';
import { t } from '../i18n/ui';

interface Props {
  lang?: Lang;
}
const { lang = 'cs' } = Astro.props;

const webLinks = lang === 'en'
  ? [
      { label: 'Why BoHeMi', href: '/en/why-bohemi/' },
      { label: 'Classes & services', href: '/en/classes-and-services/' },
      { label: '8-Week Program', href: '/program-8-tydnu/' },
      { label: 'Pricing', href: '/en/pricing/' },
      { label: 'Photos', href: '/fotky/' },
      { label: 'Contact', href: '/en/contact/' },
    ]
  : [
      { label: 'Proč BoHeMi', href: '/proc-bohemi/' },
      { label: 'Lekce a služby', href: '/lekce-a-sluzby/' },
      { label: 'Program 8 týdnů', href: '/program-8-tydnu/' },
      { label: 'Ceník', href: '/cenik/' },
      { label: 'Fotky', href: '/fotky/' },
      { label: 'Kontakt', href: '/kontakt/' },
    ];

const serviceLinks = lang === 'en'
  ? [
      { label: 'Group classes', href: '/en/group-classes/' },
      { label: 'Kids clubs', href: '/krouzky-pro-deti/' },
      { label: 'Supermums', href: '/supermamky/' },
      { label: 'Open gym', href: '/en/open-gym/' },
      { label: 'Photobiomodulation', href: '/en/photobiomodulation-therapy/' },
    ]
  : [
      { label: 'Skupinové lekce', href: '/skupinove-lekce/' },
      { label: 'Kroužky pro děti', href: '/krouzky-pro-deti/' },
      { label: 'Supermamky', href: '/supermamky/' },
      { label: 'Open gym', href: '/open-gym/' },
      { label: 'Fotobiomodulace', href: '/fotobiomodulacni-terapie/' },
      { label: 'Osobní tréninky', href: '/osobni-treninky/' },
      { label: 'Pronájem sálů', href: '/pronajem-salu/' },
      { label: 'Pro firmy', href: '/firmy/' },
    ];

const MAPS_URL = 'https://www.google.com/maps/search/?api=1&query=Vinohradsk%C3%A1%201438%2F70%2C%20Praha%203';

const socials = [
  { label: 'Facebook', href: 'https://www.facebook.com/people/Bohemi-fitness/100090517103019/' },
  { label: 'Instagram', href: 'https://www.instagram.com/bohemi.fit/' },
];

// Právní stránky ještě nejsou postavené v Astro (CLAUDE.md: "Zatím nepostavené").
// Dočasně odkazujeme na existující stránky na studio.bohemi.fit, ať odkazy
// v patičce nejsou mrtvé — až vzniknou vlastní stránky, přepsat na interní.
const legalLinks = [
  { label: t(lang, 'footer_legal_terms'), href: 'https://studio.bohemi.fit/vseobecne-obchodni-podminky/' },
  { label: t(lang, 'footer_legal_privacy'), href: 'https://studio.bohemi.fit/zpracovani-osobnich-udaju/' },
  { label: t(lang, 'footer_legal_rules'), href: 'https://studio.bohemi.fit/provozni-rad/' },
];
---
<footer id="kontakt" class="scroll-mt-24 bg-ink-dark text-cream-soft">
  <div class="mx-auto max-w-[1220px] px-5 py-16 md:px-8">
    <div class="grid grid-cols-1 gap-9 border-b border-border-dark pb-10 sm:grid-cols-2 lg:grid-cols-[1.4fr_1fr_1fr_1fr]">
      <div>
        <div class="mb-3 flex items-baseline gap-2.5">
          <span class="text-2xl font-extrabold text-cream">BoHeMi</span>
          <span class="text-sm text-sage">Body · Health · Mind</span>
        </div>
        <p class="max-w-[30ch] text-[15px] leading-relaxed">{t(lang, 'footer_tagline')}</p>
        <a
          href={RESERVE_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-5 inline-flex cursor-pointer items-center gap-2 rounded-full bg-accent-text px-5 py-2.5 text-[15px] font-bold text-cream transition-colors hover:bg-accent-deep"
        >
          {t(lang, 'footer_reserve')}
        </a>
      </div>

      <div>
        <div class="mb-3.5 text-[13px] font-bold uppercase tracking-[0.06em] text-cream-muted">{t(lang, 'footer_web')}</div>
        <div class="flex flex-col items-start gap-2.5">
          {webLinks.map((l) => (
            <a href={l.href} class="text-[15.5px] text-cream-soft hover:text-cream">{l.label}</a>
          ))}
        </div>
      </div>

      <div>
        <div class="mb-3.5 text-[13px] font-bold uppercase tracking-[0.06em] text-cream-muted">{t(lang, 'footer_services')}</div>
        <div class="flex flex-col items-start gap-2.5">
          {serviceLinks.map((l) => (
            <a href={l.href} class="text-[15.5px] text-cream-soft hover:text-cream">{l.label}</a>
          ))}
        </div>
      </div>

      <div>
        <div class="mb-3.5 text-[13px] font-bold uppercase tracking-[0.06em] text-cream-muted">{t(lang, 'footer_contact')}</div>
        <address class="text-[15.5px] not-italic leading-[1.7]">
          <a href="tel:+420603989762" class="hover:text-cream">+420 603 989 762</a><br />
          <a href="mailto:info@bohemi.fit" class="hover:text-cream">info@bohemi.fit</a><br />
          Vinohradská 1438/70, Praha 3
        </address>
        <a href={MAPS_URL} target="_blank" rel="noopener noreferrer" class="mt-2 inline-block text-[15px] font-semibold text-sage hover:text-cream">
          {t(lang, 'footer_map')}
        </a>
        <div class="mt-4 text-[13px] font-bold uppercase tracking-[0.06em] text-cream-muted">{t(lang, 'footer_hours_label')}</div>
        <div class="text-[15.5px] leading-[1.7]">{t(lang, 'footer_hours_value')}</div>
        <div class="mt-4 flex flex-wrap gap-x-4 gap-y-1.5">
          {socials.map((s) => (
            <a href={s.href} target="_blank" rel="noopener noreferrer" class="text-[15.5px] text-cream-soft hover:text-cream">{s.label}</a>
          ))}
        </div>
      </div>
    </div>

    <div class="flex flex-col gap-3 pt-6 text-[13.5px] text-cream-muted sm:flex-row sm:items-center sm:justify-between">
      <div>© BoHeMi fitness s.r.o. · IČ 19115296 · {t(lang, 'footer_rights')}</div>
      <div class="flex flex-wrap gap-x-4 gap-y-1.5">
        {legalLinks.map((l) => (
          <a href={l.href} target="_blank" rel="noopener noreferrer" class="hover:text-cream-soft">{l.label}</a>
        ))}
      </div>
    </div>
  </div>
</footer>
