---
import Eyebrow from './Eyebrow.astro';
import { triad } from '../data/home';
---
<section class="mx-auto max-w-[1220px] px-5 py-16 md:px-8 md:py-23">
  <div class="grid items-center gap-10 lg:grid-cols-[0.92fr_1.08fr] lg:gap-14">
    <div class="flex items-center justify-center">
      <div class="relative aspect-[430/400] w-[min(430px,100%)]" aria-hidden="true">
        <div class="absolute left-1/2 top-0 aspect-square w-[61%] -translate-x-1/2 rounded-full bg-accent/80 mix-blend-multiply"></div>
        <div class="absolute bottom-0 left-[2%] aspect-square w-[61%] rounded-full bg-ink/55 mix-blend-multiply"></div>
        <div class="absolute bottom-0 right-[2%] aspect-square w-[61%] rounded-full bg-gold/80 mix-blend-multiply"></div>
        <span class="absolute left-1/2 top-[9%] -translate-x-1/2 text-lg font-extrabold text-surface">Tělo</span>
        <span class="absolute bottom-[13%] left-[9%] text-lg font-extrabold text-surface">Zdraví</span>
        <span class="absolute bottom-[13%] right-[10%] text-lg font-extrabold text-ink-dark">Mysl</span>
        <span class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 text-[22px] font-extrabold text-surface [text-shadow:0_1px_6px_rgba(0,0,0,0.25)]">BoHeMi</span>
      </div>
    </div>

    <div>
      <Eyebrow>Co znamená BoHeMi</Eyebrow>
      <h2 class="mb-3 max-w-[18ch] text-[clamp(30px,4vw,48px)] font-extrabold leading-[1.03] tracking-[-0.03em]">Body, Health, Mind — prakticky.</h2>
      <p class="mb-7 max-w-[42ch] text-base leading-[1.5] text-ink-soft">Ne jako teorie, ale jako jednoduchý rámec pro každodenní život.</p>
      <div class="flex flex-col">
        {triad.map((item) => (
          <div class="flex gap-[18px] border-t border-border-strong py-5">
            <span class={`mt-[7px] h-3.5 w-3.5 shrink-0 rounded-full ${item.dot}`} aria-hidden="true"></span>
            <div>
              <div class="mb-0.5 flex items-baseline gap-2.5">
                <h3 class="text-[23px] font-extrabold tracking-[-0.02em]">{item.cs}</h3>
                <span class="text-[13px] font-semibold uppercase tracking-[0.08em] text-ink-faint">{item.k}</span>
              </div>
              <p class="max-w-[46ch] text-base leading-[1.5] text-ink-soft">{item.d}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
