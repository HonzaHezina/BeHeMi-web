---
import Eyebrow from './Eyebrow.astro';
import MediaFrame from './MediaFrame.astro';
import { Image } from 'astro:assets';
import { trainers as trainersCS } from '../data/home';
import { trainers as trainersEN } from '../data/home.en';
import { trainerPhotos } from '../data/trainer-photos';
import type { Lang } from '../i18n/ui';
import { t } from '../i18n/ui';

interface Props {
  lang?: Lang;
}
const { lang = 'cs' } = Astro.props;
const trainers = lang === 'en' ? trainersEN : trainersCS;
---
<section class="border-t border-border-strong bg-sand">
  <div class="mx-auto max-w-[1220px] px-5 py-16 md:px-8 md:py-23">
    <Eyebrow>{t(lang, 'trainers_eyebrow')}</Eyebrow>
    <div class="mb-11 flex flex-wrap items-baseline justify-between gap-4">
      <h2 class="text-[clamp(30px,4vw,48px)] font-extrabold tracking-[-0.03em]">{t(lang, 'trainers_h2')}</h2>
      {lang === 'cs' && <a href="/treneri/" class="cursor-pointer text-base font-bold text-accent-text hover:text-ink">Celý tým →</a>}
    </div>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {trainers.map((tr) => (
        <div>
          {trainerPhotos[tr.name] ? (
            <MediaFrame media={tr.media} rounded="rounded-[18px]" class="mb-4 h-70" alt={`${lang === 'en' ? 'Portrait' : 'Portrét'} — ${tr.name}`}>
              <Image
                src={trainerPhotos[tr.name]}
                alt={`${lang === 'en' ? 'Portrait' : 'Portrét'} — ${tr.name}`}
                class="h-full w-full object-cover"
                widths={[320, 640]}
                sizes="(min-width: 1024px) 25vw, 50vw"
              />
            </MediaFrame>
          ) : (
            <MediaFrame media={tr.media} rounded="rounded-[18px]" class="mb-4 h-70" alt={`${lang === 'en' ? 'Portrait' : 'Portrét'} — ${tr.name}`} />
          )}
          <h3 class="text-[21px] font-extrabold tracking-[-0.02em]">{tr.name}</h3>
          <p class="text-[15px] text-ink-muted">{tr.role}</p>
          {tr.bio && <p class="mt-1.5 text-[14.5px] leading-[1.5] text-ink-soft">{tr.bio}</p>}
        </div>
      ))}
    </div>
  </div>
</section>
