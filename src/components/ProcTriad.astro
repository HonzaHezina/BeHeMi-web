---
import Eyebrow from './Eyebrow.astro';
import Button from './Button.astro';
import { triad as triadCS } from '../data/home';
import { triad as triadEN } from '../data/home.en';
import type { Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}
const { lang = 'cs' } = Astro.props;
const procHref = lang === 'en' ? '/en/why-bohemi/' : '/proc-bohemi/';
---
<section id="proc" class="mx-auto max-w-[1220px] px-5 pb-16 md:px-8 md:pb-23">
  <div class="grid items-center gap-11 rounded-3xl border border-mint-border bg-mint p-9 md:grid-cols-2 md:p-[clamp(36px,5vw,60px)]">
    <div>
      <Eyebrow>{lang === 'en' ? 'Why BoHeMi' : 'Proč BoHeMi'}</Eyebrow>
      <h2 class="mb-[18px] text-[clamp(28px,3.6vw,44px)] font-extrabold leading-[1.04] tracking-[-0.03em]">
        {lang === 'en' ? "It's not just about pushing your body." : 'Nejde jen o to dát si do těla.'}
      </h2>
      <p class="mb-4 max-w-[46ch] text-lg leading-[1.55] text-ink-line">
        {lang === 'en'
          ? "Most people already know they should move more. The hard part is starting and sticking with it. At BoHeMi you learn to work with your body — when to push, when to slow down, how to move safely."
          : 'Většina lidí ví, že by se měla víc hýbat. Těžké je začít a vydržet. U nás se naučíš pracovat se svým tělem — kdy přidat, kdy zpomalit, jak na to bezpečně.'}
      </p>
      <p class="mb-[26px] max-w-[44ch] text-lg leading-[1.55] text-ink-line">
        {lang === 'en'
          ? 'And it shows up elsewhere too: better sleep, more energy, a clearer head.'
          : 'A projeví se to i jinde — v lepším spánku, energii i tom, jak máš srovnanou hlavu.'}
      </p>
      <Button href={procHref} variant="brand">
        {lang === 'en' ? 'Our story →' : 'Náš příběh →'}
      </Button>
    </div>

    <div class="flex flex-col items-center gap-6">
      <div class="relative aspect-[430/400] w-[min(340px,100%)]" aria-hidden="true">
        <div class="absolute left-1/2 top-0 aspect-square w-[61%] -translate-x-1/2 rounded-full bg-accent/80 mix-blend-multiply"></div>
        <div class="absolute bottom-0 left-[2%] aspect-square w-[61%] rounded-full bg-ink/55 mix-blend-multiply"></div>
        <div class="absolute bottom-0 right-[2%] aspect-square w-[61%] rounded-full bg-gold/80 mix-blend-multiply"></div>
        <span class="absolute left-1/2 top-[9%] -translate-x-1/2 text-lg font-extrabold text-surface">
          {lang === 'en' ? triadEN[0].k : triadCS[0].cs}
        </span>
        <span class="absolute bottom-[13%] left-[9%] text-lg font-extrabold text-surface">
          {lang === 'en' ? triadEN[1].k : triadCS[1].cs}
        </span>
        <span class="absolute bottom-[13%] right-[10%] text-lg font-extrabold text-ink-dark">
          {lang === 'en' ? triadEN[2].k : triadCS[2].cs}
        </span>
        <span class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 text-[22px] font-extrabold text-surface [text-shadow:0_1px_6px_rgba(0,0,0,0.25)]">BoHeMi</span>
      </div>
      <p class="max-w-[38ch] text-center text-[15px] leading-[1.5] text-ink-soft">
        {lang === 'en'
          ? <>Body · Health · Mind — three things every class works on, even a simple circuit.</>
          : <>Tělo · Zdraví · Mysl — na všech třech pracuješ v každé lekci, i na obyčejném kruháči.</>}
      </p>
    </div>
  </div>
</section>
