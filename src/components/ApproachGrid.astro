---
import Eyebrow from './Eyebrow.astro';
import { approach } from '../data/home';
---
<section class="relative overflow-hidden bg-ink-dark text-cream">
  <div
    class="pointer-events-none absolute -right-20 -top-24 h-[440px] w-[440px] rounded-full"
    style="background:radial-gradient(circle, rgba(226,35,26,0.20), rgba(226,35,26,0) 70%);"
    aria-hidden="true"
  >
  </div>
  <div class="relative mx-auto max-w-[1220px] px-5 py-20 md:px-8 md:py-24">
    <Eyebrow color="sage">Co u nás lidé nejčastěji řeší</Eyebrow>
    <h2 class="mb-6 max-w-[26ch] text-[clamp(30px,4vw,48px)] font-extrabold leading-[1.03] tracking-[-0.03em]">Vyber, co teď potřebuješ.</h2>
    <p class="mb-12 max-w-[60ch] text-[clamp(18px,2.2vw,24px)] font-normal leading-[1.4] text-cream-soft">
      Cvičení pro různé situace — začátek, kondici, záda, pravidelnost, děti, maminky i firmy.
    </p>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {approach.map((a) => (
        <div class="rounded-[18px] border border-border-dark bg-cream/[0.04] px-7 py-8 transition-all duration-300 hover:-translate-y-1.5 hover:border-sage-soft hover:bg-cream/[0.07]">
          <div class="mb-3.5 text-[30px] italic text-cream-muted" aria-hidden="true">{a.n}</div>
          <h3 class="mb-2.5 text-xl font-extrabold tracking-[-0.02em] text-cream">{a.t}</h3>
          <p class="text-[15.5px] leading-[1.5] text-cream-soft">{a.d}</p>
        </div>
      ))}
    </div>

    <p class="mt-12 max-w-[68ch] text-base leading-[1.6] text-cream-muted">
      Zní ti tohle povědomě? Pak je BoHeMi pravděpodobně pro tebe.
    </p>
  </div>
</section>
