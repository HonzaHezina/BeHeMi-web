---
import Button from './Button.astro';
import MediaFrame from './MediaFrame.astro';
import type { Lang } from '../i18n/ui';
import { t } from '../i18n/ui';

interface Props {
  lang?: Lang;
}
const { lang = 'cs' } = Astro.props;
---
<section class="relative overflow-hidden bg-ink-dark text-cream">
  <div
    class="anim-drift pointer-events-none absolute -right-16 -top-10 h-[520px] w-[520px] rounded-full blur-lg"
    style="background:radial-gradient(circle at 35% 35%, rgba(226,35,26,0.22), rgba(226,35,26,0) 68%);"
    aria-hidden="true"
  >
  </div>

  <div class="relative mx-auto grid max-w-[1220px] items-center gap-10 px-5 pb-16 pt-12 md:px-8 md:pt-18 lg:grid-cols-[1.08fr_0.92fr] lg:gap-13">
    <div>
      <div class="mb-6 inline-flex items-center gap-2.5 rounded-full border border-accent/30 bg-accent/10 px-4 py-1.5">
        <span class="h-1.5 w-1.5 rounded-full bg-accent" aria-hidden="true"></span>
        <span class="text-[13px] font-semibold uppercase tracking-[0.04em] text-cream-soft">{t(lang, 'hero_badge')}</span>
      </div>

      <h1 class="text-[clamp(44px,6.6vw,84px)] font-extrabold leading-[0.98] tracking-[-0.035em] text-cream">
        {lang === 'en' ? (
          <>Coached workouts, circuits<br />and bodyweight training <span class="font-medium text-accent">for body, health and mind.</span></>
        ) : (
          <>Vedené tréninky, kruháče<br />a vlastní váha <span class="font-medium text-accent">pro tělo, zdraví i hlavu.</span></>
        )}
      </h1>

      <p class="mt-6 max-w-[50ch] text-[clamp(18px,1.9vw,22px)] leading-[1.5] text-cream-soft">
        {t(lang, 'hero_body')}
      </p>

      <div class="mt-8 flex flex-wrap gap-3.5">
        <Button href={lang === 'en' ? '/en/classes-and-services/' : '/lekce-a-sluzby/'} variant="primary">{t(lang, 'hero_cta_primary')}</Button>
        <Button href="#nabidka" variant="outline-light">{t(lang, 'hero_cta_secondary')}</Button>
      </div>

      <div class="mt-4">
        <Button href="/krouzky-pro-deti/" variant="outline-light" class="px-5 py-2.5 text-[15px]">{t(lang, 'hero_kids_link')}</Button>
      </div>

      <div class="mt-8 flex items-center gap-5">
        <div class="flex" aria-hidden="true">
          <span class="media-clay h-10 w-10 rounded-full border-2 border-ink-dark"></span>
          <span class="media-sand -ml-3 h-10 w-10 rounded-full border-2 border-ink-dark"></span>
          <span class="media-rose -ml-3 h-10 w-10 rounded-full border-2 border-ink-dark"></span>
        </div>
        <span class="text-[14.5px] leading-snug text-cream-muted">
          {lang === 'en' ? <>Small groups —<br />your coach knows your name.</> : <>Malé skupiny —<br />trenér ví, jak na tebe.</>}
        </span>
      </div>
    </div>

    <div class="relative h-[clamp(380px,46vw,540px)]">
      <MediaFrame
        media="media-clay"
        rounded="rounded-t-[200px] rounded-b-[22px]"
        class="h-full w-full shadow-[0_30px_60px_-22px_rgba(0,0,0,0.55)]"
        alt={t(lang, 'hero_img_alt')}
      />
      <div class="anim-floaty absolute left-1 top-6 rounded-2xl border border-border bg-surface px-4 py-2.5 shadow-[0_14px_30px_-14px_rgba(0,0,0,0.45)] lg:-left-6 lg:top-8">
        <span class="text-[13px] font-bold text-accent-text">{t(lang, 'hero_float_1')}</span>
      </div>
      <div class="anim-floaty2 absolute right-1 top-[46%] rounded-2xl border border-border bg-surface px-4 py-2.5 shadow-[0_14px_30px_-14px_rgba(0,0,0,0.45)] lg:-right-5">
        <span class="text-[13px] font-bold text-ink">{t(lang, 'hero_float_2')}</span>
      </div>
      <div class="anim-floaty3 absolute bottom-5 left-1 rounded-2xl border border-border bg-surface px-4 py-2.5 shadow-[0_14px_30px_-14px_rgba(0,0,0,0.45)] lg:-left-7">
        <span class="text-[13px] font-bold text-gold-dark">{t(lang, 'hero_float_3')}</span>
      </div>
    </div>
  </div>
</section>
