---
import Button from './Button.astro';
import ClassCard from './ClassCard.astro';
import {
  classes as classesCS,
  individualServices as individualServicesCS,
  firmyServices as firmyServicesCS,
} from '../data/home';
import {
  classes as classesEN,
  individualServices as individualServicesEN,
  firmyServices as firmyServicesEN,
} from '../data/home.en';
import { photosCS, photosEN } from '../data/photos';
import type { Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}
const { lang = 'cs' } = Astro.props;

const classes = lang === 'en' ? classesEN : classesCS;
const photos = lang === 'en' ? photosEN : photosCS;
const individualServices = lang === 'en' ? individualServicesEN : individualServicesCS;
const firmyServices = lang === 'en' ? firmyServicesEN : firmyServicesCS;

const scheduleHref = lang === 'en' ? '/en/group-classes/' : '/skupinove-lekce/';
const contactHref = lang === 'en' ? '/en/contact/' : '/kontakt/';

// Nejkonkrétnější cíl lekce: vlastní stránka (page), jinak kotva na rozvrhu.
const classHref = (c: (typeof classes)[number]) => c.page ?? `${scheduleHref}#${c.id}`;
---
<section id="nabidka" class="mx-auto max-w-[1220px] px-5 md:px-8">
  <!-- ───── PRO TEBE / FOR YOU ───── -->
  <div id="pro-tebe" class="scroll-mt-24 pt-16 md:pt-16">
    <h2 class="text-[13px] font-extrabold uppercase tracking-[0.08em] text-accent-text">
      {lang === 'en' ? 'For you' : 'Pro tebe'}
    </h2>
    <p class="mt-2 max-w-[60ch] text-lg leading-[1.5] text-ink-soft">
      {lang === 'en' ? 'Individuals who want energy, strength and calm' : 'Jednotlivci, kteří chtějí energii, sílu a klid'}
    </p>
  </div>

  <!-- Blok „Lekce a programy" (data `paths`) stažen z HP 7/2026 — programy
       kromě Programu 8 týdnů ještě nejsou hotové. Vrátit, až budou. -->

  <div class="pt-9">
    <div class="mb-[22px] flex flex-wrap items-end justify-between gap-4">
      <h3 class="text-2xl font-extrabold tracking-[-0.02em]">
        {lang === 'en' ? 'Group classes' : 'Skupinové lekce'}
      </h3>
      <!-- Kotva #prvni-lekce existuje jen na CZ stránce — EN odkaz nedávat. -->
      <div class="flex flex-wrap items-baseline gap-x-6 gap-y-1">
        {lang === 'cs' && (
          <a href="/skupinove-lekce/#prvni-lekce" class="cursor-pointer text-base font-bold text-accent-text hover:text-ink">Jdeš poprvé? →</a>
        )}
        <a href={scheduleHref} class="cursor-pointer text-base font-bold text-accent-text hover:text-ink">
          {lang === 'en' ? 'Full schedule →' : 'Celý rozvrh →'}
        </a>
      </div>
    </div>
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {classes.slice(0, 6).map((c) => (
        <ClassCard
          href={classHref(c)}
          media={c.media}
          photo={photos[c.id]}
          fallbackAlt={`${lang === 'en' ? 'Class' : 'Lekce'} — ${c.img}`}
          title={c.t}
          description={c.d}
          meta={c.bhm}
          headingTag="h4"
        />
      ))}
    </div>
  </div>

  <div class="pt-12">
    <h3 class="mb-[22px] text-2xl font-extrabold tracking-[-0.02em]">
      {lang === 'en' ? 'Individual services' : 'Individuální služby'}
    </h3>
    <div class="grid gap-px overflow-hidden rounded-2xl border border-border bg-border sm:grid-cols-2 lg:grid-cols-3">
      {individualServices.map((s) => s.href ? (
        <a href={s.href} class="block cursor-pointer bg-surface p-[30px] transition-colors hover:bg-surface-hover">
          <h4 class="mb-2 text-xl font-extrabold tracking-[-0.02em]">{s.t}</h4>
          <p class="text-[15.5px] leading-[1.5] text-ink-soft">{s.d}</p>
        </a>
      ) : (
        <div class="bg-surface p-[30px]">
          <h4 class="mb-2 text-xl font-extrabold tracking-[-0.02em]">{s.t}</h4>
          <p class="text-[15.5px] leading-[1.5] text-ink-soft">{s.d}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Sekce „Pro děti a rodiny" tady byla duplicitní s KidsBand.astro výš na HP
       (stejný nadpis i odkaz na /krouzky-pro-deti/) — smazána 10. 7. 2026,
       nevracet. Dětská nabídka na HP žije jen v KidsBand. -->

  <!-- ───── PRO FIRMY / FOR COMPANIES ───── -->
  <div id="pro-firmy" class="scroll-mt-24 border-t border-border pt-14">
    <h2 class="text-[13px] font-extrabold uppercase tracking-[0.08em] text-accent-text">
      {lang === 'en' ? 'For companies' : 'Pro firmy'}
    </h2>
    <p class="mt-2 max-w-[60ch] text-lg leading-[1.5] text-ink-soft">
      {lang === 'en' ? 'A healthier and more cohesive team without your own gym' : 'Zdravější a sehranější tým bez vlastní tělocvičny'}
    </p>
  </div>

  <div class="pt-9">
    <h3 class="mb-[22px] text-2xl font-extrabold tracking-[-0.02em]">
      {lang === 'en' ? 'Services for companies' : 'Služby pro firmy'}
    </h3>
    <div class="grid gap-px overflow-hidden rounded-2xl border border-border bg-border sm:grid-cols-2 lg:grid-cols-3">
      {firmyServices.map((f) => f.href ? (
        <a href={f.href} class="block cursor-pointer bg-surface p-[30px] transition-colors hover:bg-surface-hover">
          <h4 class="mb-2 text-xl font-extrabold tracking-[-0.02em]">{f.t}</h4>
          <p class="text-[15.5px] leading-[1.5] text-ink-soft">{f.d}</p>
        </a>
      ) : (
        <div class="bg-surface p-[30px]">
          <h4 class="mb-2 text-xl font-extrabold tracking-[-0.02em]">{f.t}</h4>
          <p class="text-[15.5px] leading-[1.5] text-ink-soft">{f.d}</p>
        </div>
      ))}
    </div>
    <div class="mt-6">
      <Button href={contactHref} variant="dark" class="px-6 py-3 text-[15.5px]">
        {lang === 'en' ? 'Enquire about a company program →' : 'Poptat firemní program →'}
      </Button>
    </div>
  </div>
</section>
