---
import Button from './Button.astro';
import MediaFrame from './MediaFrame.astro';
import {
  paths,
  classes,
  individualServices,
  kidsActivities,
  firmyServices,
} from '../data/home';
---
<section id="nabidka" class="mx-auto max-w-[1220px] px-5 md:px-8">
  <!-- ───── PRO TEBE ───── -->
  <div id="pro-tebe" class="scroll-mt-24 pt-16 md:pt-16">
    <div class="flex flex-wrap items-baseline gap-x-4 gap-y-2 border-b-2 border-ink pb-[18px]">
      <span class="italic text-xl text-accent-text">01</span>
      <span class="text-[13px] font-extrabold uppercase tracking-[0.08em] text-brand">Pro tebe</span>
      <span class="text-base text-ink-muted">Jednotlivci, kteří chtějí energii, sílu a klid</span>
    </div>
  </div>

  <div class="pt-9">
    <h3 class="mb-[22px] text-2xl font-extrabold tracking-[-0.02em]">Lekce a programy</h3>
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {paths.map((p) => (
        <div class="flex min-h-[172px] flex-col rounded-2xl border border-border bg-surface p-7 transition-all duration-300 hover:-translate-y-1 hover:border-brand hover:shadow-[0_20px_40px_-20px_rgba(33,31,26,0.24)]">
          <span class="mb-3.5 text-[12.5px] font-bold uppercase tracking-[0.06em] text-accent-text">{p.tag}</span>
          <h4 class="mb-2 text-[21px] font-extrabold tracking-[-0.02em]">{p.t}</h4>
          <p class="text-[15.5px] leading-[1.5] text-ink-soft">{p.d}</p>
        </div>
      ))}
    </div>
  </div>

  <div class="pt-12">
    <div class="mb-[22px] flex flex-wrap items-end justify-between gap-4">
      <h3 class="text-2xl font-extrabold tracking-[-0.02em]">Skupinové lekce</h3>
      <a href="/skupinove-lekce/" class="cursor-pointer text-base font-bold text-accent-text hover:text-ink">Celý rozvrh →</a>
    </div>
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {classes.map((c) => (
        <div class="overflow-hidden rounded-2xl border border-border bg-surface transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_20px_40px_-20px_rgba(33,31,26,0.24)]">
          <MediaFrame media={c.media} rounded="rounded-none" class="h-40" alt={`Lekce — ${c.img}`} />
          <div class="p-[22px]">
            <h4 class="mb-2 text-[21px] font-extrabold tracking-[-0.02em]">{c.t}</h4>
            <p class="text-[15.5px] leading-[1.5] text-ink-soft">{c.d}</p>
            <div class="mt-3 text-[12.5px] font-bold tracking-[0.02em] text-brand">{c.bhm}</div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="pt-12">
    <h3 class="mb-[22px] text-2xl font-extrabold tracking-[-0.02em]">Individuální služby</h3>
    <div class="grid gap-px overflow-hidden rounded-2xl border border-border bg-border sm:grid-cols-2 lg:grid-cols-3">
      {individualServices.map((s) => (
        <div class="bg-surface p-[30px] transition-colors hover:bg-surface-hover">
          <h4 class="mb-2 text-xl font-extrabold tracking-[-0.02em]">{s.t}</h4>
          <p class="text-[15.5px] leading-[1.5] text-ink-soft">{s.d}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- ───── PRO DĚTI ───── -->
  <div id="pro-deti" class="scroll-mt-24 pt-18">
    <div class="flex flex-wrap items-baseline gap-x-4 gap-y-2 border-b-2 border-ink pb-[18px]">
      <span class="italic text-xl text-accent-text">02</span>
      <span class="text-[13px] font-extrabold uppercase tracking-[0.08em] text-brand">Pro děti a rodiny</span>
      <span class="text-base text-ink-muted">Pohyb pro nejmenší i pro maminky</span>
    </div>
  </div>

  <div class="pt-9">
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {kidsActivities.map((k) => (
        <div class="overflow-hidden rounded-2xl border border-border bg-surface transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_20px_40px_-20px_rgba(33,31,26,0.24)]">
          <MediaFrame media={k.media} rounded="rounded-none" class="h-40" alt={`Pro děti — ${k.img}`} />
          <div class="p-[22px]">
            <h4 class="mb-2 text-[21px] font-extrabold tracking-[-0.02em]">{k.t}</h4>
            <p class="text-[15.5px] leading-[1.5] text-ink-soft">{k.d}</p>
          </div>
        </div>
      ))}
    </div>
    <p class="mt-5 max-w-[60ch] text-base text-ink-soft">A pro maminky tu máme <strong class="font-bold">Supermamky</strong> — trénink, kam můžeš vzít i dítě.</p>
  </div>

  <!-- ───── PRO FIRMY ───── -->
  <div id="pro-firmy" class="scroll-mt-24 pt-18">
    <div class="flex flex-wrap items-baseline gap-x-4 gap-y-2 border-b-2 border-ink pb-[18px]">
      <span class="italic text-xl text-accent-text">03</span>
      <span class="text-[13px] font-extrabold uppercase tracking-[0.08em] text-brand">Pro firmy</span>
      <span class="text-base text-ink-muted">Zdravější a sehranější tým bez vlastní tělocvičny</span>
    </div>
  </div>

  <div class="pt-9">
    <div class="grid gap-px overflow-hidden rounded-2xl border border-border bg-border sm:grid-cols-2 lg:grid-cols-3">
      {firmyServices.map((f) => (
        <div class="bg-surface p-[30px] transition-colors hover:bg-surface-hover">
          <h4 class="mb-2 text-xl font-extrabold tracking-[-0.02em]">{f.t}</h4>
          <p class="text-[15.5px] leading-[1.5] text-ink-soft">{f.d}</p>
        </div>
      ))}
    </div>
    <div class="mt-6">
      <Button href="/kontakt/" variant="dark" class="px-6 py-3 text-[15.5px]">Poptat firemní program →</Button>
    </div>
  </div>
</section>
