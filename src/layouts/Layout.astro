---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'BoHeMi — Body, Health, Mind',
  description = '',
} = Astro.props;

// Indexace je vázaná na prostředí. Web je indexovatelný JEN když je
// PUBLIC_SITE_ENV === 'production'. Cokoliv jiného (staging, preview, lokál)
// i nenastavená proměnná = noindex,nofollow — staging nikdy neproklouzne do
// Googlu. ⚠️ PRODUKČNÍ DEPLOY MUSÍ MÍT PUBLIC_SITE_ENV=production, jinak bude
// celý web noindex. Nastavení v Coolify viz README.
const isProduction = import.meta.env.PUBLIC_SITE_ENV === 'production';
---
<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    {/* Žádný <meta name="generator"> — zbytečně prozrazuje verzi Astra. */}
    {!isProduction && <meta name="robots" content="noindex,nofollow" />}
    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,500;1,600&display=swap"
      rel="stylesheet"
    />

    <slot name="head" />
  </head>
  <body>
    <div class="grain-overlay" aria-hidden="true"></div>
    <slot />
  </body>
</html>
