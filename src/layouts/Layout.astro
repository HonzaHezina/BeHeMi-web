---
import '../styles/global.css';
import type { Lang } from '../i18n/ui';
import { hreflangMap } from '../i18n/ui';

interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
  current?: string;
}
const {
  title = 'BoHeMi — Body, Health, Mind',
  description = '',
  lang = 'cs',
  current = '/',
} = Astro.props;

const isProduction = import.meta.env.PUBLIC_SITE_ENV === 'production';
const hreflang = hreflangMap[current] ?? null;
const origin = 'https://bohemi.fit';
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    {/* Žádný <meta name="generator"> — zbytečně prozrazuje verzi Astra. */}
    {!isProduction && <meta name="robots" content="noindex,nofollow" />}
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {hreflang && <link rel="alternate" hreflang="cs" href={`${origin}${hreflang.cs}`} />}
    {hreflang && <link rel="alternate" hreflang="en" href={`${origin}${hreflang.en}`} />}
    {hreflang && <link rel="alternate" hreflang="x-default" href={`${origin}${hreflang.cs}`} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,500;1,600&display=swap"
      rel="stylesheet"
    />

    <slot name="head" />
  </head>
  <body>
    <div class="grain-overlay" aria-hidden="true"></div>
    <slot />
  </body>
</html>
